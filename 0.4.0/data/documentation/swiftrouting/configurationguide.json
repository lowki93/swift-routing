,{"inlineContent":[{"type":"text","text":"When a route cannot be matched, SwiftRouting emits "},{"type":"codeVoice","code":".error(RouterError.routeNotFound)"},{"type":"text","text":" before either crashing or displaying the fallback message. Use this in your logger to monitor unresolved routes in production:"}],"type":"paragraph"},{"type":"codeListing","code":["Configuration(logger: { config in","    if case .error(let error) = config.message {","        \/\/ Report to your error tracking service","        Analytics.record(error.description)","    }","})"],"syntax":"swift"},{"anchor":"Custom-Logger-Examples","type":"heading","level":2,"text":"Custom Logger Examples"},{"anchor":"Analytics-Integration","type":"heading","level":3,"text":"Analytics Integration"},{"inlineContent":[{"text":"Send navigation events to your analytics service:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["let config = Configuration(","    logger: { loggerConfig in","        switch loggerConfig.message {","        case .navigation(let from, let to, let type):","            Analytics.track(\"navigation\", properties: [","                \"from\": from.name,","                \"to\": to.name,","                \"type\": \"\\(type)\"","            ])","        default:","            break","        }","    },","    shouldCrashOnRouteNotFound: false",")"],"syntax":"swift"},{"anchor":"Debug-Logging","type":"heading","level":3,"text":"Debug Logging"},{"inlineContent":[{"type":"text","text":"Detailed logging for development:"}],"type":"paragraph"},{"type":"codeListing","code":["let config = Configuration(","    logger: { loggerConfig in","        let routerId = loggerConfig.router.id.uuidString.prefix(8)","        ","        switch loggerConfig.message {","        case .create(let from, _):","            if let parent = from {","                print(\"🆕 [\\(routerId)] Created from \\(parent)\")","            } else {","                print(\"🆕 [\\(routerId)] Root router created\")","            }","            ","        case .delete:","            print(\"🗑️ [\\(routerId)] Deallocated\")","            ","        case .navigation(let from, let to, let type):","            print(\"🧭 [\\(routerId)] \\(from.name) → \\(to.name) (\\(type))\")","            ","        case .action(let action):","            print(\"⚡ [\\(routerId)] Action: \\(action)\")","            ","        case .context(let context):","            print(\"📦 [\\(routerId)] Context: \\(context)\")","            ","        case .onAppear(let route):","            print(\"👁️ [\\(routerId)] Appear: \\(route.name)\")","            ","        case .onDisappear(let route):","            print(\"👁️‍🗨️ [\\(routerId)] Disappear: \\(route.name)\")","        }","    },","    shouldCrashOnRouteNotFound: true",")"],"syntax":"swift"},{"anchor":"Filtered-Logging","type":"heading","level":3,"text":"Filtered Logging"},{"inlineContent":[{"type":"text","text":"Log only specific events:"}],"type":"paragraph"},{"type":"codeListing","code":["let config = Configuration(","    logger: { loggerConfig in","        switch loggerConfig.message {","        case .navigation, .action:","            LoggerConfiguration.default(loggerConfiguration: loggerConfig)","        default:","            break","        }","    },","    shouldCrashOnRouteNotFound: false",")"],"syntax":"swift"},{"anchor":"Disable-Logging","type":"heading","level":3,"text":"Disable Logging"},{"inlineContent":[{"text":"To disable logging entirely, pass ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":":","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["let config = Configuration(","    logger: nil,","    shouldCrashOnRouteNotFound: false",")"],"syntax":"swift"},{"anchor":"Environment-Based-Configuration","type":"heading","level":2,"text":"Environment-Based Configuration"},{"inlineContent":[{"type":"text","text":"Use different configurations for debug and release builds:"}],"type":"paragraph"},{"type":"codeL