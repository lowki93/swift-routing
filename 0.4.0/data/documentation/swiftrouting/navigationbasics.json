{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiftrouting\/navigationbasics"]}],"metadata":{"roleHeading":"Article","role":"article","title":"Navigation Basics","modules":[{"name":"SwiftRouting"}]},"hierarchy":{"paths":[["doc:\/\/SwiftRouting\/documentation\/SwiftRouting"],["doc:\/\/SwiftRouting\/documentation\/SwiftRouting","doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/FAQ"],["doc:\/\/SwiftRouting\/documentation\/SwiftRouting","doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/Migration"]]},"sections":[],"kind":"article","schemaVersion":{"patch":0,"minor":3,"major":0},"seeAlsoSections":[{"generated":true,"anchor":"Navigation","title":"Navigation","identifiers":["doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/RouterModel","doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/BaseRouterModel"]}],"primaryContentSections":[{"content":[{"anchor":"Overview","text":"Overview","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/Router","type":"reference","isActive":true},{"type":"text","text":" is your primary interface for programmatic navigation. Every "},{"identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/RoutingView","type":"reference","isActive":true},{"type":"text","text":" creates its own router, accessible via the SwiftUI environment."}],"type":"paragraph"},{"anchor":"Accessing-the-Router","text":"Accessing the Router","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Use the "},{"type":"codeVoice","code":"@Environment"},{"type":"text","text":" property wrapper to access the router:"}],"type":"paragraph"},{"syntax":"swift","code":["struct MyView: View {","    @Environment(\\.router) private var router","    ","    var body: some View {","        Button(\"Navigate\") {","            router.push(HomeRoute.detail(id: 42))","        }","    }","}"],"type":"codeListing"},{"anchor":"Push-Navigation","text":"Push Navigation","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Push adds a route to the navigation stack with a standard slide animation:"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Push a new route","router.push(HomeRoute.detail(id: 42))","","\/\/ Using NavigationLink","NavigationLink(route: HomeRoute.detail(id: 42)) {","    Text(\"View Details\")","}"],"type":"codeListing"},{"anchor":"NavigationLink-Behavior","text":"NavigationLink Behavior","type":"heading","level":3},{"inlineContent":[{"type":"codeVoice","code":"NavigationLink(route:)"},{"type":"text","text":" is push-only (stack navigation), because it uses"},{"type":"text","text":" "},{"type":"codeVoice","code":"NavigationLink(value:)"},{"type":"text","text":" with route values."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Important notes:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"It must be used inside a ","type":"text"},{"type":"codeVoice","code":"RoutingView"},{"text":" configured with a matching ","type":"text"},{"type":"codeVoice","code":"RouteDestination"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"It does not perform modal presentation, even if the route has a modal "},{"type":"codeVoice","code":"routingType"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"For modal flows, prefer "},{"code":"router.present(...)","type":"codeVoice"},{"type":"text","text":" or "},{"code":"router.cover(...)","type":"codeVoice"},{"type":"text","text":"."}]}]}],"type":"unorderedList"},{"anchor":"Modal-Presentations","text":"Modal Presentations","type":"heading","level":2},{"anchor":"Sheet","text":"Sheet","type":"heading","level":3},{"inlineContent":[{"text":"Present a route as a modal sheet:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ With navigation stack (default)","router.present(HomeRoute.settings)","","\/\/ Without navigation stack","router.present(HomeRoute.settings, withStack: false)"],"type":"codeListing"},{"inlineContent":[{"text":"Use ","type":"text"},{"type":"codeVoice","code":"withStack: false"},{"text":" when the presented destination needs direct sheet modifiers such as:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":[".presentationDetents([.medium])",".presentationDragIndicator(.visible)"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"With "},{"type":"codeVoice","code":"withStack: true"},{"type":"text","text":" (default), the route is wrapped in a "},{"type":"codeVoice","code":"RoutingView"},{"type":"text","text":"\/"},{"type":"codeVoice","code":"NavigationStack"},{"type":"text","text":", which can make these modifiers less predictable on the final destination view."}],"type":"paragraph"},{"anchor":"Full-Screen-Cover","text":"Full-Screen Cover","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"Present a route as a full-screen cover:"}],"type":"paragraph"},{"syntax":"swift","code":["router.cover(HomeRoute.onboarding)"],"type":"codeListing"},{"anchor":"Navigating-Back","text":"Navigating Back","type":"heading","level":2},{"anchor":"Back-One-Step","text":"Back One Step","type":"heading","level":3},{"inlineContent":[{"text":"Remove the top route from the stack:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["router.back()"],"type":"codeListing"},{"anchor":"Pop-to-Root","text":"Pop to Root","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"Return to the root of the navigation stack:"}],"type":"paragraph"},{"syntax":"swift","code":["router.popToRoot()"],"type":"codeListing"},{"anchor":"Close-Modal","text":"Close Modal","type":"heading","level":3},{"inlineContent":[{"text":"Dismiss a presented sheet or cover:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["router.close()"],"type":"codeListing"},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"code":"close()","type":"codeVoice"},{"text":" only works on routers that are presented (sheets or covers).","type":"text"}]}],"type":"aside","name":"Note"},{"anchor":"Updating-the-Root","text":"Updating the Root","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Replace the current root route:"}],"type":"paragraph"},{"syntax":"swift","code":["router.update(root: HomeRoute.dashboard)"],"type":"codeListing"},{"inlineContent":[{"text":"This is useful for scenarios like switching between logged-in and logged-out states.","type":"text"}],"type":"paragraph"},{"anchor":"Using-routingType","text":"Using routingType","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Instead of calling specific methods, you can use "},{"type":"codeVoice","code":"route(_:)"},{"type":"text","text":" which respects the route’s "},{"type":"codeVoice","code":"routingType"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ This will use the route's defined routingType","router.route(HomeRoute.settings)","","\/\/ Equivalent to checking routingType and calling the appropriate method","switch route.routingType {","case .push: router.push(route)","case .sheet: router.present(route)","case .cover: router.cover(route)","case .root: router.update(root: route)","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"For routes that require sheet presentation customizations ("},{"type":"codeVoice","code":"presentationDetents"},{"type":"text","text":", "},{"type":"codeVoice","code":"presentationDragIndicator"},{"type":"text","text":"), prefer:"}],"type":"paragraph"},{"syntax":"swift","code":["var routingType: RoutingType { .sheet(withStack: false) }"],"type":"codeListing"},{"anchor":"Router-Properties","text":"Router Properties","type":"heading","level":2},{"inlineContent":[{"text":"The router provides useful properties for UI decisions:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Check if this router is presented as a modal","if router.isPresented {","    Button(\"Close\") { router.close() }","}","","\/\/ Get the current route","let current = router.currentRoute","","\/\/ Check navigation depth","if router.routeCount > 1 {","    Button(\"Back\") { router.back() }","}"],"type":"codeListing"},{"anchor":"Injecting-Router-into-ViewModels","text":"Injecting Router into ViewModels","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"For MVVM architectures, inject the router using "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/RouterModel"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"swift","code":["class DetailViewModel: ObservableObject {","    private let router: any RouterModel","    ","    init(router: any RouterModel) {","        self.router = router","    }","    ","    func goToSettings() {","        router.present(HomeRoute.settings)","    }","}","","struct DetailView: View {","    @Environment(\\.router) private var router","    @StateObject private var viewModel: DetailViewModel","    ","    init() {","        \/\/ Note: Initialize in onAppear or use a factory","    }","    ","    var body: some View {","        \/\/ ...","    }","}"],"type":"codeListing"},{"anchor":"App-Level-Convenience-Overloads-Optional","text":"App-Level Convenience Overloads (Optional)","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"If your app uses one main route enum (for example "},{"code":"HomeRoute","type":"codeVoice"},{"type":"text","text":"), you can add"},{"type":"text","text":" "},{"code":"RouterModel","type":"codeVoice"},{"type":"text","text":" overloads to improve call-site ergonomics:"}],"type":"paragraph"},{"syntax":"swift","code":["public extension RouterModel {","    @_disfavoredOverload","    func push(_ homeRoute: HomeRoute) {","        push(homeRoute)","    }","","    @_disfavoredOverload","    func update(root homeRoute: HomeRoute) {","        update(root: homeRoute)","    }","}"],"type":"codeListing"},{"inlineContent":[{"text":"Before:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["router.push(HomeRoute.profile)","router.update(root: HomeRoute.home)"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"After:"}],"type":"paragraph"},{"syntax":"swift","code":["router.push(.profile)","router.update(root: .home)"],"type":"codeListing"},{"inlineContent":[{"text":"Use this pattern for your main route type only, to keep overload resolution predictable.","type":"text"}],"type":"paragraph"},{"anchor":"Closing-Child-Routers","text":"Closing Child Routers","type":"heading","level":2},{"inlineContent":[{"text":"When handling deep links or resetting navigation, close all presented modals:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["router.closeChildren()"],"type":"codeListing"},{"inlineContent":[{"text":"This dismisses any sheets or covers presented from this router.","type":"text"}],"type":"paragraph"},{"anchor":"Targeting-the-Frontmost-Router","text":"Targeting the Frontmost Router","type":"heading","level":2},{"inlineContent":[{"text":"Inside a ","type":"text"},{"code":"RoutingView","type":"codeVoice"},{"text":", ","type":"text"},{"code":"@Environment(\\.router)","type":"codeVoice"},{"text":" always gives you the router for that view.","type":"text"},{"text":" ","type":"text"},{"text":"But at the ","type":"text"},{"code":"@main","type":"codeVoice"},{"text":" App level — where no environment is available — you hold a reference to","type":"text"},{"text":" ","type":"text"},{"text":"the root router directly. In that case, use ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/BaseRouter\/deepestRouter()"},{"text":" to target whichever","type":"text"},{"text":" ","type":"text"},{"text":"router is actually on screen at the moment the action fires:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["@main","struct MyApp: App {","  @State var rootRouter = Router(configuration: .default)","","  var body: some Scene {","    WindowGroup {","      ContentView()","        .environment(rootRouter)","        .onOpenURL { url in","          Task { @MainActor in","            rootRouter.deepestRouter()?.terminate(MyContext())","          }","        }","    }","  }","}"],"type":"codeListing"},{"inlineContent":[{"code":"deepestRouter()","type":"codeVoice"},{"text":" traverses the router tree depth-first, following the last live child at each","type":"text"},{"text":" ","type":"text"},{"text":"level until it reaches a leaf with no active children. If no child is active, it returns the","type":"text"},{"text":" ","type":"text"},{"text":"receiver itself.","type":"text"}],"type":"paragraph"},{"style":"important","content":[{"type":"paragraph","inlineContent":[{"text":"Call ","type":"text"},{"code":"deepestRouter()","type":"codeVoice"},{"text":" at dispatch time, not at setup time.","type":"text"},{"text":" ","type":"text"},{"text":"If a modal is on screen when the action fires, ","type":"text"},{"code":"deepestRouter()","type":"codeVoice"},{"text":" returns that modal’s router","type":"text"},{"text":" ","type":"text"},{"text":"so ","type":"text"},{"code":"terminate(_:)","type":"codeVoice"},{"text":" unwinds through the correct presenter.","type":"text"}]}],"type":"aside","name":"Important"}],"kind":"content"}],"abstract":[{"text":"Learn how to navigate between routes using the Router.","type":"text"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/NavigationBasics"},"references":{"doc://SwiftRouting/documentation/SwiftRouting":{"identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting","type":"topic","url":"\/documentation\/swiftrouting","abstract":[{"type":"text","text":"A lightweight, type-safe navigation framework built on top of NavigationStack for SwiftUI."}],"title":"SwiftRouting","role":"collection","kind":"symbol"},"doc://SwiftRouting/documentation/SwiftRouting/BaseRouterModel":{"kind":"symbol","url":"\/documentation\/swiftrouting\/baseroutermodel","type":"topic","navigatorTitle":[{"text":"BaseRouterModel","kind":"identifier"}],"identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/BaseRouterModel","abstract":[{"type":"text","text":"Defines the base navigation capabilities shared by all router types."}],"role":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"BaseRouterModel","kind":"identifier"}],"title":"BaseRouterModel"},"doc://SwiftRouting/documentation/SwiftRouting/RoutingView":{"kind":"symbol","identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/RoutingView","type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"RoutingView"}],"title":"RoutingView","url":"\/documentation\/swiftrouting\/routingview","abstract":[{"type":"text","text":"Creates a navigation container with its own "},{"code":"Router","type":"codeVoice"},{"type":"text","text":"."}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"RoutingView"}]},"doc://SwiftRouting/documentation/SwiftRouting/RouterModel":{"url":"\/documentation\/swiftrouting\/routermodel","kind":"symbol","identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/RouterModel","type":"topic","abstract":[{"type":"text","text":"Defines navigation capabilities within a "},{"type":"codeVoice","code":"ViewModel"},{"type":"text","text":" or other components."}],"role":"symbol","navigatorTitle":[{"text":"RouterModel","kind":"identifier"}],"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"RouterModel","kind":"identifier"}],"title":"RouterModel"},"doc://SwiftRouting/documentation/SwiftRouting/Router":{"identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/Router","title":"Router","kind":"symbol","url":"\/documentation\/swiftrouting\/router","type":"topic","navigatorTitle":[{"text":"Router","kind":"identifier"}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Router","kind":"identifier"}],"abstract":[{"type":"text","text":"Every "},{"code":"RoutingView","type":"codeVoice"},{"type":"text","text":" has his own router"}],"role":"symbol"},"doc://SwiftRouting/documentation/SwiftRouting/FAQ":{"role":"collectionGroup","kind":"article","identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/FAQ","type":"topic","abstract":[{"type":"text","text":"Answers to common questions about SwiftRouting usage and design decisions."}],"url":"\/documentation\/swiftrouting\/faq","title":"FAQ"},"doc://SwiftRouting/documentation/SwiftRouting/BaseRouter/deepestRouter()":{"title":"deepestRouter()","type":"topic","kind":"symbol","url":"\/documentation\/swiftrouting\/baserouter\/deepestrouter()","identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/BaseRouter\/deepestRouter()","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"deepestRouter","kind":"identifier"},{"text":"() -> ","kind":"text"},{"preciseIdentifier":"s:12SwiftRouting6RouterC","text":"Router","kind":"typeIdentifier"},{"text":"?","kind":"text"}],"abstract":[],"role":"symbol"},"doc://SwiftRouting/documentation/SwiftRouting/Migration":{"type":"topic","role":"collectionGroup","title":"Migrating from NavigationStack","identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/Migration","url":"\/documentation\/swiftrouting\/migration","abstract":[{"text":"Adopt SwiftRouting in an existing SwiftUI app with minimal disruption.","type":"text"}],"kind":"article"}}}