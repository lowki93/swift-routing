{"primaryContentSections":[{"content":[{"level":2,"anchor":"Overview","text":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"If your app already uses "},{"type":"codeVoice","code":"NavigationStack"},{"type":"text","text":", "},{"type":"codeVoice","code":"NavigationLink"},{"type":"text","text":", or native sheet\/cover modifiers, you can migrate to SwiftRouting incrementally. This guide walks through each common pattern and shows the equivalent SwiftRouting code."}],"type":"paragraph"},{"level":2,"anchor":"NavigationStack-%E2%86%92-RoutingView","text":"NavigationStack → RoutingView","type":"heading"},{"level":3,"anchor":"Before","text":"Before","type":"heading"},{"syntax":"swift","code":["@State private var path = NavigationPath()","","var body: some View {","    NavigationStack(path: $path) {","        HomeView()","            .navigationDestination(for: String.self) { value in","                if value == \"detail\" {","                    DetailView()","                } else if value == \"settings\" {","                    SettingsView()","                }","            }","    }","}"],"type":"codeListing"},{"level":3,"anchor":"After","text":"After","type":"heading"},{"inlineContent":[{"text":"Define your routes as a Swift enum, then replace the stack with ","type":"text"},{"identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/RoutingView","type":"reference","isActive":true},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["enum HomeRoute: Route {","    case home","    case detail(id: Int)","    case settings","","    var name: String {","        switch self {","        case .home: \"home\"","        case .detail(let id): \"detail(\\(id))\"","        case .settings: \"settings\"","        }","    }","}","","extension HomeRoute: RouteDestination {","    static func view(for route: HomeRoute) -> some View {","        switch route {","        case .home: HomeView()","        case .detail(let id): DetailView(id: id)","        case .settings: SettingsView()","        }","    }","}","","var body: some View {","    RoutingView(destination: HomeRoute.self, root: .home)","}"],"type":"codeListing"},{"inlineContent":[{"text":"All ","type":"text"},{"type":"codeVoice","code":"navigationDestination"},{"text":" registrations are replaced by a single ","type":"text"},{"type":"codeVoice","code":"RouteDestination"},{"text":" conformance.","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"NavigationLink-%E2%86%92-routerpush","text":"NavigationLink → router.push","type":"heading"},{"level":3,"anchor":"Before","text":"Before","type":"heading"},{"syntax":"swift","code":["NavigationLink(\"View Details\", value: \"detail\")","","\/\/ Or with a destination view","NavigationLink(\"View Details\") {","    DetailView(id: 42)","}"],"type":"codeListing"},{"level":3,"anchor":"After","text":"After","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"type":"codeVoice","code":"router.push(_:)"},{"type":"text","text":" or the SwiftRouting "},{"type":"codeVoice","code":"NavigationLink(route:)"},{"type":"text","text":" extension:"}]},{"code":["\/\/ Programmatic push","Button(\"View Details\") {","    router.push(HomeRoute.detail(id: 42))","}","","\/\/ Declarative NavigationLink","NavigationLink(\"View Details\", route: HomeRoute.detail(id: 42))"],"type":"codeListing","syntax":"swift"},{"style":"important","content":[{"inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":"NavigationLink(route:)"},{"type":"text","text":" performs push navigation only. For modal presentation, use "},{"type":"codeVoice","code":"router.present(_:)"},{"type":"text","text":" or "},{"type":"codeVoice","code":"router.cover(_:)"},{"type":"text","text":"."}],"type":"paragraph"}],"name":"Important","type":"aside"},{"anchor":"Sheets-%E2%86%92-routerpresent","text":"Sheets → router.present","type":"heading","level":2},{"anchor":"Before","text":"Before","type":"heading","level":3},{"code":["@State private var showSettings = false","","var body: some View {","    Button(\"Open Settings\") {","        showSettings = true","    }","    .sheet(isPresented: $showSettings) {","        SettingsView()","    }","}"],"type":"codeListing","syntax":"swift"},{"anchor":"After","text":"After","type":"heading","level":3},{"code":["@Environment(\\.router) private var router","","Button(\"Open Settings\") {","    router.present(HomeRoute.settings)","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you need sheet presentation modifiers such as "},{"type":"codeVoice","code":"presentationDetents"},{"type":"text","text":", present without a navigation stack:"}]},{"code":["\/\/ In your route definition","var routingType: RoutingType { .sheet(withStack: false) }","","\/\/ Or inline","router.present(HomeRoute.settings, withStack: false)"],"type":"codeListing","syntax":"swift"},{"anchor":"Full-Screen-Cover-%E2%86%92-routercover","text":"Full-Screen Cover → router.cover","type":"heading","level":2},{"anchor":"Before","text":"Before","type":"heading","level":3},{"code":["@State private var showOnboarding = false","","var body: some View {","    Button(\"Start Onboarding\") {","        showOnboarding = true","    }","    .fullScreenCover(isPresented: $showOnboarding) {","        OnboardingView()","    }","}"],"type":"codeListing","syntax":"swift"},{"anchor":"After","text":"After","type":"heading","level":3},{"code":["Button(\"Start Onboarding\") {","    router.cover(HomeRoute.onboarding)","}"],"type":"codeListing","syntax":"swift"},{"anchor":"TabView-%E2%86%92-RoutingTabView","text":"TabView → RoutingTabView","type":"heading","level":2},{"anchor":"Before","text":"Before","type":"heading","level":3},{"code":["@State private var selectedTab = 0","","TabView(selection: $selectedTab) {","    HomeView()","        .tabItem { Label(\"Home\", systemImage: \"house\") }","        .tag(0)","","    SearchView()","        .tabItem { Label(\"Search\", systemImage: \"magnifyingglass\") }","        .tag(1)","","    ProfileView()","        .tabItem { Label(\"Profile\", systemImage: \"person\") }","        .tag(2)","}"],"type":"codeListing","syntax":"swift"},{"anchor":"After-Option-1-RoutingTabView-recommended","text":"After — Option 1: RoutingTabView (recommended)","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"code":"RoutingTabView","type":"codeVoice"},{"text":" when you need programmatic cross-tab navigation via ","type":"text"},{"identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/TabRouter","isActive":true,"type":"reference"},{"text":":","type":"text"}]},{"code":["enum HomeTab: TabRoute {","    case home","    case search","    case profile","","    var name: String {","        switch self {","        case .home: \"home\"","        case .search: \"search\"","        case .profile: \"profile\"","        }","    }","}","","struct ContentView: View {","    @State private var selectedTab: HomeTab = .home","","    var body: some View {","        RoutingTabView(tab: $selectedTab, destination: HomeRoute.self) { destination in","            RoutingView(tab: .home, destination: destination, root: .home)","                .tabItem { Label(\"Home\", systemImage: \"house\") }","","            RoutingView(tab: .search, destination: destination, root: .search)","                .tabItem { Label(\"Search\", systemImage: \"magnifyingglass\") }","","            RoutingView(tab: .profile, destination: destination, root: .profile)","                .tabItem { Label(\"Profile\", systemImage: \"person\") }","        }","    }","}"],"type":"codeListing","syntax":"swift"},{"anchor":"After-Option-2-Native-TabView-with-tabToRoot","text":"After — Option 2: Native TabView with .tabToRoot","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"For simpler cases without programmatic tab control:"}]},{"code":["struct ContentView: View {","    @Environment(\\.router) private var router","    @State private var selectedTab: HomeTab = .home","","    var body: some View {","        TabView(selection: .tabToRoot(for: $selectedTab, in: router)) {","            RoutingView(tab: .home, destination: HomeRoute.self, root: .home)","                .tabItem { Label(\"Home\", systemImage: \"house\") }","","            RoutingView(tab: .search, destination: HomeRoute.self, root: .search)","                .tabItem { Label(\"Search\", systemImage: \"magnifyingglass\") }","","            RoutingView(tab: .profile, destination: HomeRoute.self, root: .profile)","                .tabItem { Label(\"Profile\", systemImage: \"person\") }","        }","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":".tabToRoot"},{"type":"text","text":" binding automatically pops to root when the user taps the already-selected tab."}]},{"style":"important","content":[{"inlineContent":[{"type":"text","text":"This option does "},{"type":"strong","inlineContent":[{"type":"text","text":"not"}]},{"type":"text","text":" provide "},{"type":"codeVoice","code":"@Environment(\\.tabRouter)"},{"type":"text","text":". Use "},{"type":"codeVoice","code":"RoutingTabView"},{"type":"text","text":" when cross-tab programmatic navigation is needed."}],"type":"paragraph"}],"name":"Important","type":"aside"},{"anchor":"Deep-Links","text":"Deep Links","type":"heading","level":2},{"anchor":"Before","text":"Before","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Deep link handling typically required parsing URLs and manually mutating "},{"type":"codeVoice","code":"NavigationPath"},{"type":"text","text":":"}]},{"code":[".onOpenURL { url in","    if url.path == \"\/detail\" {","        path.append(\"detail\")","    }","}"],"type":"codeListing","syntax":"swift"},{"anchor":"After","text":"After","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Define a typed identifier enum ("},{"code":"Hashable & Sendable","type":"codeVoice"},{"type":"text","text":") to represent your deep link inputs, then implement "},{"type":"reference","identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/DeeplinkHandler","isActive":true},{"type":"text","text":" to map it to a "},{"type":"reference","identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/DeeplinkRoute","isActive":true},{"type":"text","text":":"}]},{"code":["enum AppDeeplinkIdentifier: Hashable, Sendable {","    case detail(id: Int)","}","","extension AppDeeplinkIdentifier {","    init?(url: URL) {","        switch url.path {","        case \"\/detail\":","            guard let id = Int(url.lastPathComponent) else { return nil }","            self = .detail(id: id)","        default:","            return nil","        }","    }","}","","struct HomeDeeplinkHandler: DeeplinkHandler {","    typealias R = AppDeeplinkIdentifier","    typealias D = HomeRoute","","    func deeplink(from route: AppDeeplinkIdentifier) async throws -> DeeplinkRoute<HomeRoute>? {","        switch route {","        case .detail(let id):","            return .push(.detail(id: id))","        }","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Parse the URL into the identifier inside ","type":"text"},{"type":"codeVoice","code":".onOpenURL"},{"text":", then pass it to the handler:","type":"text"}]},{"code":["struct HomeRootView: View {","    @Environment(\\.router) private var router","    let handler = HomeDeeplinkHandler()","","    var body: some View {","        HomeView()","            .onOpenURL { url in","                Task {","                    guard let identifier = AppDeeplinkIdentifier(url: url) else { return }","                    guard let deeplink = try? await handler.deeplink(from: identifier) else { return }","                    router.handle(deeplink: deeplink)","                }","            }","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/Deeplinks"},{"text":" for advanced patterns including path building, async data fetching, and tab-aware deep linking.","type":"text"}]},{"anchor":"Dismissing-Modals","text":"Dismissing Modals","type":"heading","level":2},{"anchor":"Before","text":"Before","type":"heading","level":3},{"code":["@Environment(\\.dismiss) private var dismiss","","Button(\"Close\") {","    dismiss()","}"],"type":"codeListing","syntax":"swift"},{"anchor":"After","text":"After","type":"heading","level":3},{"code":["@Environment(\\.router) private var router","","Button(\"Close\") {","    router.close()","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"code":"router.close()","type":"codeVoice"},{"type":"text","text":" dismisses the current presented modal. It is a no-op if the router is not presented."}]}],"kind":"content"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"topicSections":[{"title":"Related","identifiers":["doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/GettingStarted","doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/NavigationBasics","doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/Deeplinks","doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/RoutingView","doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/RouterModel","doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/DeeplinkHandler"],"anchor":"Related"}],"sections":[],"abstract":[{"type":"text","text":"Adopt SwiftRouting in an existing SwiftUI app with minimal disruption."}],"metadata":{"title":"Migrating from NavigationStack","modules":[{"name":"SwiftRouting"}],"role":"collectionGroup","roleHeading":"API Collection"},"kind":"article","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiftRouting\