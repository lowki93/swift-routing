":"paragraph","inlineContent":[{"type":"text","text":"Optional route to set as the new root (default: "},{"code":"nil","type":"codeVoice"},{"type":"text","text":")"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"type"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Presentation type for the final route: "},{"type":"codeVoice","code":".push"},{"type":"text","text":", "},{"type":"codeVoice","code":".sheet(withStack:)"},{"type":"text","text":", or "},{"type":"codeVoice","code":".cover"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"route","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Optional final destination route (default: ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" for reset scenarios)","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"path"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Array of intermediate routes to push first (default: "},{"code":"[]","type":"codeVoice"},{"type":"text","text":")"}]}]]],"header":"row","type":"table"},{"style":"note","content":[{"inlineContent":[{"type":"text","text":"When "},{"type":"codeVoice","code":"route"},{"type":"text","text":" is "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" (e.g., with "},{"type":"codeVoice","code":".popToRoot()"},{"type":"text","text":"), the final navigation step is skipped. The "},{"type":"codeVoice","code":"type"},{"type":"text","text":" parameter is set automatically by factory methods."}],"type":"paragraph"}],"name":"Note","type":"aside"},{"level":2,"anchor":"Handling-Deep-Links","text":"Handling Deep Links","type":"heading"},{"inlineContent":[{"type":"text","text":"Use the router’s "},{"type":"codeVoice","code":"handle(deeplink:)"},{"type":"text","text":" method:"}],"type":"paragraph"},{"syntax":"swift","code":["struct ContentView: View {","    var body: some View {","        RoutingView(destination: HomeRoute.self, root: .home) {","            HomeRootView()","        }","    }","}","","struct HomeRootView: View {","    @Environment(\\.router) private var router","    let handler = AppDeeplinkHandler()","","    var body: some View {","        HomeView()","            .onOpenURL { url in","                Task {","                    guard let identifier = DeeplinkIdentifier(url: url) else { return }","                    guard let deeplink = try await handler.deeplink(from: identifier) else { return }","                    router.handle(deeplink: deeplink)","                }","            }","    }","}"],"type":"codeListing"},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"type":"text","text":" "},{"type":"text","text":"The route type returned by "},{"type":"codeVoice","code":"DeeplinkHandler"},{"type":"text","text":" ("},{"type":"codeVoice","code":"D"},{"type":"text","text":") must match the route type used by "},{"type":"codeVoice","code":"RoutingView(destination:root:)"},{"type":"text","text":"."}]}],"name":"Note","type":"aside"},{"level":3,"anchor":"What-handledeeplink-Does","text":"What handle(deeplink:) Does","type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Closes all presented modals (","type":"text"},{"code":"closeChildren()","type":"codeVoice"},{"text":")","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Pops to the root ("},{"code":"popToRoot()","type":"codeVoice"},{"type":"text","text":")"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Optionally updates the root route (if "},{"type":"codeVoice","code":"root"},{"type":"text","text":" is set)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Pushes intermediate routes from "},{"type":"codeVoice","code":"path"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Navigates to the final route with the specified type (only if "},{"type":"codeVoice","code":"route"},{"type":"text","text":" is not "},{"type":"codeVoice","code":"nil"},{"type":"text","text":")"}],"type":"paragraph"}]}],"type":"orderedList"},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Step 5 is skipped when "},{"type":"codeVoice","code":"route"},{"type":"text","text":" is "},{"type":"codeVoice","code":"nil"},{"type":"text","text":", making "},{"type":"codeVoice","code":".popToRoot()"},{"type":"text","text":" and "},{"type":"codeVoice","code":".updateRoot(_:)"},{"type":"text","text":" useful for reset scenarios without a final destination."}]}],"name":"Note","type":"aside"},{"level":3,"anchor":"Complete-Example","text":"Complete Example","type":"heading"},{"syntax":"swift","code":["\/\/ Deep link: reset to dashboard, build path, then push detail as sheet",".present(","    .orderDetail(id: orderId),","    root: .dashboard,","    path: [.orders, .orderList]",")"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"This will:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"Close any presented modals","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Pop to root"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Set ","type":"text"},{"code":".dashboard","type":"codeVoice"},{"text":" as the new root","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Push ","type":"text"},{"code":".orders","type":"codeVoice"},{"text":" then ","type":"text"},{"code":".orderList","type":"codeVoice"},{"text":" onto the stack","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Present "},{"type":"codeVoice","code":".orderDetail(id:)"},{"type":"text","text":" as a sheet"}],"type":"paragraph"}]}],"type":"orderedList"},{"level":2,"anchor":"Async-Deep-Link-Handling","text":"Async Deep Link Handling","type":"heading"},{"inlineContent":[{"text":"The ","type":"text"},{"code":"deeplink(from:)","type":"codeVoice"},{"text":" method is ","type":"text"},{"code":"async","type":"codeVoice"},{"text":", allowing you to fetch data before navigation:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["func deeplink(from route: DeeplinkIdentifier) async throws -> DeeplinkRoute<HomeRoute>? {","    switch route {","    case .product(let productId):","        \/\/ Fetch product details before navigating","        let product = try await productService.fetch(id: productId)","        return .push(.productDetail(product))","        ","    case .user(let userId):","        \/\/ Validate user exists","        guard await userService.exists(id: userId) else {","            return nil  \/\/ Return nil to ignore invalid deep links","        }","        return .push(.profile(userId: userId))","        ","    default:","        return nil","    }","}"],"type":"codeListing"},{"level":2,"anchor":"Composing-Deeplink-Handlers-Nested-Route-Logic","text":"Composing Deeplink Handlers (Nested Route Logic)","type":"heading"},{"inlineContent":[{"type":"text","text":"For larger apps, compose deep link handling by feature instead of keeping all cases in one switch."},{"type":"text","text":" "},{"type":"text","text":"This works well with nested route structures."}],"type":"paragraph"},{"syntax":"swift","code":["enum AppRoute: Route {","    case home","    case profile(ProfileRoute)","","    var name: String {","        switch self {","        case .home: \"home\"","        case .profile(let child): \"profile.\\(child.name)\"","        }","    }","}","","enum ProfileRoute: Route {","    case overview","    case edit(userId: String)","","    var name: String {","        switch self {","        case .overview: \"overview\"","        case .edit(let userId): \"edit(\\(userId))\"","        }","    }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Create feature-level handlers:"}],"type":"paragraph"},{"syntax":"swift","code":["enum ProfileDeeplinkID: Hashable, Sendable {","    case profile(userId: String)","    case editProfile(userId: String)","}","","struct ProfileDeeplinkHandler: DeeplinkHandler {","    typealias R = ProfileDeeplinkID","    typealias D = AppRoute","","    func deeplink(from route: ProfileDeeplinkID) async throws -> DeeplinkRoute<AppRoute>? {","        switch route {","        case .profile(let userId):","            return .push(.profile(.overview), path: [.home])","        case .editProfile(let userId):","            return .push(.profile(.edit(userId: userId)))","        }","    }","}"],"type":"codeListing"},{"inlineContent":[{"text":"Then compose at the app level:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["enum AppDeeplinkID: Hashable, Sendable {","    case home","    case profile(ProfileDeeplinkID)","    case reset","}","","struct AppDeeplinkHandler: DeeplinkHandler {","    typealias R = AppDeeplinkID","    typealias D = AppRoute","","    private let profileHandler = ProfileDeeplinkHandler()","","    func deeplink(from route: AppDeeplinkID) async throws -> DeeplinkRoute<AppRoute>? {","        switch route {","        case .home:","            return .push(.home)","        case .profile(let profileID):","            return try await profileHandler.deeplink(from: profileID)","        case .reset:","            return .popToRoot()","        }","    }","}"],"type":"codeListing"},{"inlineContent":[{"text":"Benefits:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"keeps handlers small and feature-focused","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"mirrors your nested route architecture","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"makes deeplink behavior easier to test"}]}]}],"type":"unorderedList"},{"level":2,"anchor":"Tab-Based-Deep-Links","text":"Tab-Based Deep Links","type":"heading"},{"inlineContent":[{"type":"text","text":"For apps with tab navigation, implement "},{"identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/TabDeeplinkHandler","type":"reference","isActive":true},{"type":"text","text":" and return a "},{"identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/TabDeeplink","type":"reference","isActive":true},{"type":"text","text":". The "},{"type":"codeVoice","code":"deeplink"},{"type":"text","text":" property accepts any "},{"identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/DeeplinkRoute","type":"reference","isActive":true},{"type":"text","text":", including reset scenarios with "},{"type":"codeVoice","code":".popToRoot()"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"swift","code":["struct AppTabDeeplinkHandler: TabDeeplinkHandler {","    typealias R = DeeplinkIdentifier","    typealias T = HomeTab","    typealias D = HomeRoute","","    func deeplink(from route: DeeplinkIdentifier) async throws -> TabDeeplink<HomeTab, HomeRoute>? {","        switch route {","        case .profile(let userId):","            return TabDeeplink(","                tab: .profile,","                deeplink: .push(.profile(userId: userId))","            )","            ","        case .search(let query):","            return TabDeeplink(","                tab: .search,","                deeplink: .push(.searchResults(query: query), path: [.search])","            )","            ","        case .resetHome:","            return TabDeeplink(tab: .home, deeplink: .popToRoot())","            ","        default:","            return nil","        }","    }","}"],"type":"codeListing"},{"inlineContent":[{"text":"The ","type":"text"},{"code":"handle(tabDeeplink:)","type":"codeVoice"},{"text":" method switches to the specified tab, then delegates to ","type":"text"},{"code":"handle(deeplink:)","type":"codeVoice"},{"text":" on that tab’s router. This means all ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/DeeplinkRoute","type":"reference"},{"text":" factories work seamlessly within tabs, including ","type":"text"},{"code":".popToRoot()","type":"codeVoice"},{"text":" for resetting a specific tab’s navigation.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Handle with TabRouter:"}],"type":"paragraph"},{"syntax":"swift","code":["@Environment(\\.router) private var router","","func handleDeeplink(_ url: URL) async throws {","    guard let identifier = DeeplinkIdentifier(url: url) else { return }","    guard let tabDeeplink = try await handler.deeplink(from: identifier) else { return }","    router.tabRouter?.handle(tabDeeplink: tabDeeplink)","}"],"type":"codeListing"},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"type":"text","text":" "},{"type":"codeVoice","code":"tabRouter"},{"type":"text","text":" is injected inside "},{"type":"codeVoice","code":"RoutingTabView"},{"type":"text","text":" descendants."},{"type":"text","text":" "},{"type":"text","text":"If deeplink handling is implemented in a parent container that owns "},{"type":"codeVoice","code":"RoutingTabView"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"use "},{"type":"codeVoice","code":"@Environment(\\.router)"},{"type":"text","text":" and then "},{"type":"codeVoice","code":"router.tabRouter"},{"type":"text","text":" to access the tab router."}]}],"name":"Note","type":"aside"},{"level":2,"anchor":"Building-Navigation-Paths","text":"Building Navigation Paths","type":"heading"},{"inlineContent":[{"text":"For complex deep links, build a path of intermediate routes:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Deep link to: Home → Category → Subcategory → Product",".push(","    .product(id: productId),","    path: [","        .category(id: categoryId),","        .subcategory(id: subcategoryId)","    ]",")"],"type":"codeListing"},{"inlineContent":[{"text":"This ensures the back button works correctly through the entire h