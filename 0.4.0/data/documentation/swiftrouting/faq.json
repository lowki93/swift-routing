era)","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"You want to prevent accidental swipe-to-dismiss","type":"text"}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"Both support navigation stacks inside them via the "},{"type":"codeVoice","code":"withStack"},{"type":"text","text":" parameter on "},{"type":"codeVoice","code":"present(_:)"},{"type":"text","text":":"}],"type":"paragraph"},{"code":["\/\/ Sheet with its own NavigationStack (default)","router.present(AppRoute.form)","","\/\/ Sheet without a NavigationStack (single view only)","router.present(AppRoute.form, withStack: false)","","\/\/ Full-screen cover (always has its own stack)","router.cover(AppRoute.onboarding)"],"type":"codeListing","syntax":"swift"},{"type":"thematicBreak"},{"anchor":"How-do-I-share-a-router-between-views","text":"How do I share a router between views?","level":2,"type":"heading"},{"inlineContent":[{"text":"See ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/NavigationBasics"},{"text":" for accessing the router via ","type":"text"},{"code":"@Environment(\\.router)","type":"codeVoice"},{"text":", and ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/DefiningRoutes"},{"text":" for injecting it into ViewModels via a ","type":"text"},{"code":"RouteDestination","type":"codeVoice"},{"text":" wrapper.","type":"text"}],"type":"paragraph"},{"type":"thematicBreak"},{"anchor":"Why-use-RouteContext-instead-of-callbacks","text":"Why use RouteContext instead of callbacks?","level":2,"type":"heading"},{"inlineContent":[{"text":"Callbacks (closures passed as parameters) are a common pattern for passing data back from a child view, but they come with drawbacks in a deep navigation hierarchy:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Callbacks:","type":"text"}]}],"type":"paragraph"},{"code":["\/\/ Every layer must forward the closure manually","router.push(AppRoute.picker(onSelect: { user in","    self.selectedUser = user","}))"],"type":"codeListing","syntax":"swift"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Couples the route to the callback signature"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Must be threaded through every intermediate view","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Hard to refactor when the hierarchy changes","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"RouteContext:","type":"text"}]}],"type":"paragraph"},{"code":["\/\/ Parent registers once",".routerContext(UserSelectionContext.self) { context in","    selectedUser = context.selectedUser","}","","\/\/ Child sends when done, regardless of depth","router.terminate(UserSelectionContext(selectedUser: user))"],"type":"codeListing","syntax":"swift"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Decoupled: sender and receiver don’t reference each other"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Propagates up through the entire router hierarchy automatically"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Works the same whether the child is one or five levels deep","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Enables "},{"code":"terminate(_:)","type":"codeVoice"},{"type":"text","text":" to handle both data passing and navigation in one call"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"text":"Use callbacks for simple, same-level communication. Use ","type":"text"},{"identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/RouteContext","isActive":true,"type":"reference"},{"text":" when data needs to travel up multiple levels or when the navigati