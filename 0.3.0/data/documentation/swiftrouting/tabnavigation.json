":true},{"type":"text","text":":"}]},{"type":"codeListing","syntax":"swift","code":["enum HomeTab: TabRoute {","    case home","    case search","    case profile","    ","    var name: String {","        switch self {","        case .home: \"Home\"","        case .search: \"Search\"","        case .profile: \"Profile\"","        }","    }","}"]},{"type":"heading","text":"Option 1: Using RoutingTabView","anchor":"Option-1-Using-RoutingTabView","level":2},{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/RoutingTabView"},{"type":"text","text":" provides a "},{"type":"codeVoice","code":"TabRouter"},{"type":"text","text":" for programmatic tab control:"}]},{"type":"codeListing","syntax":"swift","code":["struct ContentView: View {","    @State private var selectedTab: HomeTab = .home","    ","    var body: some View {","        RoutingTabView(tab: $selectedTab, destination: HomeRoute.self) { destination in","            RoutingView(tab: HomeTab.home, destination: destination, root: .home)","                .tabItem { Label(\"Home\", systemImage: \"house\") }","            ","            RoutingView(tab: HomeTab.search, destination: destination, root: .search)","                .tabItem { Label(\"Search\", systemImage: \"magnifyingglass\") }","            ","            RoutingView(tab: HomeTab.profile, destination: destination, root: .profile)","                .tabItem { Label(\"Profile\", systemImage: \"person\") }","        }","    }","}"]},{"type":"heading","text":"Option 2: Using Native TabView","anchor":"Option-2-Using-Native-TabView","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"For simpler cases, use SwiftUI’s "},{"type":"codeVoice","code":"TabView"},{"type":"text","text":" with the "},{"type":"codeVoice","code":".tabToRoot"},{"type":"text","text":" binding:"}]},{"type":"codeListing","syntax":"swift","code":["struct ContentView: View {","    @Environment(\\.router) private var router","    @State private var selectedTab: HomeTab = .home","    ","    var body: some View {","        TabView(selection: .tabToRoot(for: $selectedTab, in: router)) {","            RoutingView(tab: HomeTab.home, destination: HomeRoute.self, root: .home)","                .tabItem { Label(\"Home\", systemImage: \"house\") }","            ","            RoutingView(tab: HomeTab.search, destination: HomeRoute.self, root: .search)","                .tabItem { Label(\"Search\", systemImage: \"magnifyingglass\") }","            ","            RoutingView(tab: HomeTab.profile, destination: HomeRoute.self, root: .profile)","                .tabItem { Label(\"Profile\", systemImage: \"person\") }","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"code":".tabToRoot","type":"codeVoice"},{"type":"text","text":" binding automatically pops to root when the user taps the already-selected tab."}]},{"type":"aside","name":"Important","style":"important","content":[{"inlineContent":[{"text":"","type":"text"},{"text":" ","type":"text"},{"text":"This native ","type":"text"},{"type":"codeVoice","code":"TabView"},{"text":" approach does ","type":"text"},{"inlineContent":[{"type":"text","text":"not"}],"type":"strong"},{"text":" provide a ","type":"text"},{"type":"codeVoice","code":"TabRouter"},{"text":" in the environment.","type":"text"},{"text":" ","type":"text"},{"text":"Use ","type":"text"},{"type":"codeVoice","code":"RoutingTabView"},{"text":" when you need ","type":"text"},{"type":"codeVoice","code":"@Environment(\\.tabRouter)"},{"text":" and cross-tab programmatic actions.","type":"text"}],"type":"paragraph"}]},{"type":"heading","text":"Using TabRouter","anchor":"Using-TabRouter","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Access the "},{"identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/TabRouter","type":"reference","isActive":true},{"type":"text","text":" from the environment to navigate across tabs:"}]},{"type":"codeListing","syntax":"swift","code":["struct SomeView: View {","    @Environment(\\.tabRouter) private var tabRouter","    ","    var body: some View {","        Button(\"Go to Profile\") {","            \/\/ Switch to profile tab and push a route","            tabRouter?.push(HomeRoute.settings, in: HomeTab.profile)","        }","    }","}"]},{"type":"heading","text":"App-Level Convenience Overloads (Optional)","anchor":"App-Level-Convenience-Overloads-Optional","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"If your app uses one main route enum with nested feature routes, you can add"},{"type":"text","text":" "},{"type":"codeVoice","code":"TabRouterModel"},{"type":"text","text":" overloads to improve call-site ergonomics (for example using"},{"type":"text","text":" "},{"type":"codeVoice","code":".profile(...)"},{"type":"text","text":" directly at call sites)."}]},{"type":"codeListing","syntax":"swift","code":["public extension TabRouterModel {","    @_disfavoredOverload","    func push(_ homeRoute: HomeRoute) {","        push(homeRoute, in: nil)","    }","","    @_disfavoredOverload","    func update(root homeRoute: HomeRoute) {","        update(root: homeRoute, in: nil)","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Before:"}]},{"type":"codeListing","syntax":"swift","code":["tabRouter.push(HomeRoute.profile, in: nil)","tabRouter.present(HomeRoute.settings, in: nil)","tabRouter.update(root: HomeRoute.home, in: nil)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"After:"}]},{"type":"codeListing","syntax":"swift","code":["tabRouter.push(.profile)","tabRouter.present(.settings)","tabRouter.update(root: .home)"]},{"type":"paragraph","inlineContent":[{"text":"Use this pattern for your main route type only, to keep overload resolution predictable.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can apply the same pattern fo