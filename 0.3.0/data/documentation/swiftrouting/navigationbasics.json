uting":{"role":"collection","kind":"symbol","abstract":[{"type":"text","text":"A lightweight, type-safe navigation framework built on top of NavigationStack for SwiftUI."}],"title":"SwiftRouting","url":"\/documentation\/swiftrouting","identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting","type":"topic"},"doc://SwiftRouting/documentation/SwiftRouting/Migration":{"abstract":[{"text":"Adopt SwiftRouting in an existing SwiftUI app with minimal disruption.","type":"text"}],"identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/Migration","url":"\/documentation\/swiftrouting\/migration","kind":"article","type":"topic","role":"collectionGroup","title":"Migrating from NavigationStack"}}}