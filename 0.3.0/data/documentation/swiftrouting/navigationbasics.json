{"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"Learn how to navigate between routes using the Router."}],"sections":[],"hierarchy":{"paths":[["doc:\/\/SwiftRouting\/documentation\/SwiftRouting"],["doc:\/\/SwiftRouting\/documentation\/SwiftRouting","doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/FAQ"],["doc:\/\/SwiftRouting\/documentation\/SwiftRouting","doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/Migration"]]},"metadata":{"modules":[{"name":"SwiftRouting"}],"title":"Navigation Basics","role":"article","roleHeading":"Article"},"identifier":{"url":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/NavigationBasics","interfaceLanguage":"swift"},"kind":"article","seeAlsoSections":[{"generated":true,"anchor":"Navigation","title":"Navigation","identifiers":["doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/RouterModel","doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/BaseRouterModel"]}],"primaryContentSections":[{"content":[{"anchor":"Overview","text":"Overview","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/Router","type":"reference","isActive":true},{"type":"text","text":" is your primary interface for programmatic navigation. Every "},{"identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/RoutingView","type":"reference","isActive":true},{"type":"text","text":" creates its own router, accessible via the SwiftUI environment."}],"type":"paragraph"},{"anchor":"Accessing-the-Router","text":"Accessing the Router","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Use the "},{"type":"codeVoice","code":"@Environment"},{"type":"text","text":" property wrapper to access the router:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["struct MyView: View {","    @Environment(\\.router) private var router","    ","    var body: some View {","        Button(\"Navigate\") {","            router.push(HomeRoute.detail(id: 42))","        }","    }","}"]},{"anchor":"Push-Navigation","text":"Push Navigation","type":"heading","level":2},{"inlineContent":[{"text":"Push adds a route to the navigation stack with a standard slide animation:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["\/\/ Push a new route","router.push(HomeRoute.detail(id: 42))","","\/\/ Using NavigationLink","NavigationLink(route: HomeRoute.detail(id: 42)) {","    Text(\"View Details\")","}"]},{"anchor":"NavigationLink-Behavior","text":"NavigationLink Behavior","type":"heading","level":3},{"inlineContent":[{"type":"codeVoice","code":"NavigationLink(route:)"},{"text":" is push-only (stack navigation), because it uses","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"NavigationLink(value:)"},{"text":" with route values.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Important notes:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"It must be used inside a ","type":"text"},{"code":"RoutingView","type":"codeVoice"},{"text":" configured with a matching ","type":"text"},{"code":"RouteDestination","type":"codeVoice"},{"text":".","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"It does not perform modal presentation, even if the route has a modal "},{"type":"codeVoice","code":"routingType"},{"type":"text","text":"."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"For modal flows, prefer ","type":"text"},{"code":"router.present(...)","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"router.cover(...)","type":"codeVoice"},{"text":".","type":"text"}]}]}]},{"text":"Modal Presentations","anchor":"Modal-Presentations","type":"heading","level":2},{"text":"Sheet","anchor":"Sheet","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Present a route as a modal sheet:"}]},{"code":["\/\/ With navigation stack (default)","router.present(HomeRoute.settings)","","\/\/ Without navigation stack","router.present(HomeRoute.settings, withStack: false)"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"code":"withStack: false","type":"codeVoice"},{"text":" when the presented destination needs direct sheet modifiers such as:","type":"text"}]},{"code":[".presentationDetents([.medium])",".presentationDragIndicator(.visible)"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"With "},{"type":"codeVoice","code":"withStack: true"},{"type":"text","text":" (default), the route is wrapped in a "},{"type":"codeVoice","code":"RoutingView"},{"type":"text","text":"\/"},{"type":"codeVoice","code":"NavigationStack"},{"type":"text","text":", which can make these modifiers less predictable on the final destination view."}]},{"text":"Full-Screen Cover","anchor":"Full-Screen-Cover","type":"heading","level":3},{"inlineContent":[{"text":"Present a route as a full-screen cover:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["router.cover(HomeRoute.onboarding)"],"type":"codeListing"},{"anchor":"Navigating-Back","level":2,"text":"Navigating Back","type":"heading"},{"anchor":"Back-One-Step","level":3,"text":"Back One Step","type":"heading"},{"inlineContent":[{"text":"Remove the top route from the stack:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["router.back()"],"type":"codeListing"},{"anchor":"Pop-to-Root","level":3,"text":"Pop to Root","type":"heading"},{"inlineContent":[{"text":"Return to the root of the navigation stack:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["router.popToRoot()"],"type":"codeListing"},{"anchor":"Close-Modal","level":3,"text":"Close Modal","type":"heading"},{"inlineContent":[{"text":"Dismiss a presented sheet or cover:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["router.close()"],"type":"codeListing"},{"style":"note","content":[{"inlineContent":[{"type":"text","text":""},{"code":"close()","type":"codeVoice"},{"type":"text","text":" only works on routers that are presented (sheets or covers)."}],"type":"paragraph"}],"name":"Note","type":"aside"},{"anchor":"Updating-the-Root","level":2,"text":"Updating the Root","type":"heading"},{"inlineContent":[{"type":"text","text":"Replace the current root route:"}],"type":"paragraph"},{"syntax":"swift","code":["router.update(root: HomeRoute.dashboard)"],"type":"codeListing"},{"inlineContent":[{"text":"This is useful for scenarios like switching between logged-in and logged-out states.","type":"text"}],"type":"paragraph"},{"anchor":"Using-routingType","level":2,"text":"Using routingType","type":"heading"},{"inlineContent":[{"text":"Instead of calling specific methods, you can use ","type":"text"},{"code":"route(_:)","type":"codeVoice"},{"text":" which respects the route’s ","type":"text"},{"code":"routingType","type":"codeVoice"},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ This will use the route's defined routingType","router.route(HomeRoute.settings)","","\/\/ Equivalent to checking routingType and calling the appropriate method","switch route.routingType {","case .push: router.push(route)","case .sheet: router.present(route)","case .cover: router.cover(route)","case .root: router.update(root: route)","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"For routes that require sheet presentation customizations ("},{"type":"codeVoice","code":"presentationDetents"},{"type":"text","text":", "},{"type":"codeVoice","code":"presentationDragIndicator"},{"type":"text","text":"), prefer:"}],"type":"paragraph"},{"syntax":"swift","code":["var routingType: RoutingType { .sheet(withStack: false) }"],"type":"codeListing"},{"anchor":"Router-Properties","level":2,"text":"Router Properties","type":"heading"},{"inlineContent":[{"type":"text","text":"The router provides useful properties for UI decisions:"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Check if this router is presented as a modal","if router.isPresented {","    Button(\"Close\") { router.close() }","}","","\/\/ Get the current route","let current = router.currentRoute","","\/\/ Check navigation depth","if router.routeCount > 1 {","    Button(\"Back\") { router.back() }","}"],"type":"codeListing"},{"anchor":"Injecting-Router-into-ViewModels","level":2,"text":"Injecting Router into ViewModels","type":"heading"},{"inlineContent":[{"text":"For MVVM architectures, inject the router using ","type":"text"},{"identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/RouterModel","type":"reference","isActive":true},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["class DetailViewModel: ObservableObject {","    private let router: any RouterModel","    ","    init(router: any RouterModel) {","        self.router = router","    }","    ","    func goToSettings() {","        router.present(HomeRoute.settings)","    }","}","","struct DetailView: View {","    @Environment(\\.router) private var router","    @StateObject private var viewModel: DetailViewModel","    ","    init() {","        \/\/ Note: Initialize in onAppear or use a factory","    }","    ","    var body: some View {","        \/\/ ...","    }","}"],"type":"codeListing"},{"anchor":"App-Level-Convenience-Overloads-Optional","level":2,"text":"App-Level Convenience Overloads (Optional)","type":"heading"},{"inlineContent":[{"text":"If your app uses one main route enum (for example ","type":"text"},{"code":"HomeRoute","type":"codeVoice"},{"text":"), you can add","type":"text"},{"text":" ","type":"text"},{"code":"RouterModel","type":"codeVoice"},{"text":" overloads to improve call-site ergonomics:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["public extension RouterModel {","    @_disfavoredOverload","    func push(_ homeRoute: HomeRoute) {","        push(homeRoute)","    }","","    @_disfavoredOverload","    func update(root homeRoute: HomeRoute) {","        update(root: homeRoute)","    }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Before:"}],"type":"paragraph"},{"syntax":"swift","code":["router.push(HomeRoute.profile)","router.update(root: HomeRoute.home)"],"type":"codeListing"},{"inlineContent":[{"text":"After:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["router.push(.profile)","router.update(root: .home)"],"type":"codeListing"},{"inlineContent":[{"text":"Use this pattern for your main route type only, to keep overload resolution predictable.","type":"text"}],"type":"paragraph"},{"anchor":"Closing-Child-Routers","level":2,"text":"Closing Child Routers","type":"heading"},{"inlineContent":[{"text":"When handling deep links or resetting navigation, close all presented modals:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["router.closeChildren()"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"This dismisses any sheets or covers presented from this router."}],"type":"paragraph"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiftrouting\/navigationbasics"]}],"references":{"doc://SwiftRouting/documentation/SwiftRouting/BaseRouterModel":{"navigatorTitle":[{"kind":"identifier","text":"BaseRouterModel"}],"url":"\/documentation\/swiftrouting\/baseroutermodel","identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/BaseRouterModel","type":"topic","abstract":[{"text":"Defines the base navigation capabilities shared by all router types.","type":"text"}],"title":"BaseRouterModel","kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"BaseRouterModel"}]},"doc://SwiftRouting/documentation/SwiftRouting/FAQ":{"type":"topic","abstract":[{"type":"text","text":"Answers to common questions a