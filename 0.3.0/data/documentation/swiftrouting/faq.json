graph"},{"syntax":"swift","code":["\/\/ Every layer must forward the closure manually","router.push(AppRoute.picker(onSelect: { user in","    self.selectedUser = user","}))"],"type":"codeListing"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Couples the route to the callback signature"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Must be threaded through every intermediate view"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Hard to refactor when the hierarchy changes"}]}]}]},{"inlineContent":[{"inlineContent":[{"type":"text","text":"RouteContext:"}],"type":"strong"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Parent registers once",".routerContext(UserSelectionContext.self) { context in","    selectedUser = context.selectedUser","}","","\/\/ Child sends when done, regardless of depth","router.terminate(UserSelectionContext(selectedUser: user))"],"type":"codeListing"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Decoupled: sender and receiver don’t reference each other","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Propagates up through the entire router hierarchy automatically"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Works the same whether the child is one or five levels deep","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Enables ","type":"text"},{"type":"codeVoice","code":"terminate(_:)"},{"text":" to handle both data passing and navigation in one call","type":"text"}]}]}]},{"inlineContent":[{"text":"Use callbacks for simple, same-level communication. Use ","type":"text"},{"identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/RouteContext","type":"reference","isActive":true},{"text":" when data needs to travel up multiple levels or when the navigation flow should complete on context