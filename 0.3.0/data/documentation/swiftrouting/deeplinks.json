{"metadata":{"roleHeading":"API Collection","role":"collectionGroup","title":"Deep Linking","modules":[{"name":"SwiftRouting"}]},"schemaVersion":{"patch":0,"major":0,"minor":3},"topicSections":[{"anchor":"Related","identifiers":["doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/DeeplinkRoute","doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/DeeplinkHandler","doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/TabDeeplinkHandler","doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/DeeplinkRoute","doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/TabDeeplink"],"title":"Related"}],"variants":[{"paths":["\/documentation\/swiftrouting\/deeplinks"],"traits":[{"interfaceLanguage":"swift"}]}],"seeAlsoSections":[{"generated":true,"anchor":"Deep-Linking","identifiers":["doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/DeeplinkHandler","doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/TabDeeplinkHandler","doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/DeeplinkRoute","doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/TabDeeplink"],"title":"Deep Linking"}],"sections":[],"abstract":[{"type":"text","text":"Learn how to handle deep links and navigate to specific routes."}],"primaryContentSections":[{"content":[{"level":2,"anchor":"Overview","type":"heading","text":"Overview"},{"inlineContent":[{"type":"text","text":"SwiftRouting provides a flexible deep linking system through "},{"identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/DeeplinkHandler","isActive":true,"type":"reference"},{"type":"text","text":", "},{"identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/TabDeeplinkHandler","isActive":true,"type":"reference"},{"type":"text","text":", "},{"identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/DeeplinkRoute","isActive":true,"type":"reference"},{"type":"text","text":", and "},{"identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/TabDeeplink","isActive":true,"type":"reference"},{"type":"text","text":"."}],"type":"paragraph"},{"level":2,"anchor":"Creating-a-Deeplink-Handler","type":"heading","text":"Creating a Deeplink Handler"},{"inlineContent":[{"type":"text","text":"Implement "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/DeeplinkHandler"},{"type":"text","text":" to convert incoming URLs or identifiers into navigation routes:"}],"type":"paragraph"},{"code":["struct AppDeeplinkHandler: DeeplinkHandler {","    typealias R = DeeplinkIdentifier  \/\/ Your input type","    typealias D = HomeRoute           \/\/ Your route type","    ","    func deeplink(from route: DeeplinkIdentifier) async throws -> DeeplinkRoute<HomeRoute>? {","        switch route {","        case .home:","            return .push(.home)","            ","        case .userProfile(let userId):","            return .push(.profile(userId: userId))","            ","        case .settings:","            return .present(.settings)","            ","        case .reset:","            return .popToRoot()","            ","        default:","            return nil","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"level":3,"anchor":"Choosing-the-Right-Factory","type":"heading","text":"Choosing the Right Factory"},{"header":"row","type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Scenario","type":"text"}]}],[{"inlineContent":[{"text":"Factory","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Navigate to a screen in the stack"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":".push(_:)"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Show a modal sheet"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":".present(_:)"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Show a full-screen modal"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":".cover(_:)"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Reset navigation (logout, clear state)","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":".popToRoot()"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Change root without clearing stack"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":".updateRoot(_:)"}],"type":"paragraph"}]]]},{"level":2,"anchor":"DeeplinkRoute-Structure","type":"heading","text":"DeeplinkRoute Structure"},{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/DeeplinkRoute"},{"text":" defines how to navigate to a destination. Use factory methods for common scenarios:","type":"text"}],"type":"paragraph"},{"code":["\/\/ Push a route onto the navigation stack",".push(.detail(id: 1))","","\/\/ Push with intermediate routes (builds navigation hierarchy)",".push(.detail(id: 1), path: [.list, .category(id: 5)])","","\/\/ Push with a new root",".push(.detail(id: 1), root: .home, path: [.list])","","\/\/ Present as a sheet",".present(.settings)",".present(.settings, withStack: false)  \/\/ Without navigation stack","","\/\/ Present as a full-screen cover",".cover(.onboarding)","","\/\/ Reset navigation without navigating to a new route",".popToRoot()",".popToRoot(root: .home)  \/\/ Reset and update root","","\/\/ Update root without additional navigation",".updateRoot(.dashboard)"],"syntax":"swift","type":"codeListing"},{"level":3,"anchor":"Factory-Methods","type":"heading","text":"Factory Methods"},{"header":"row","type":"table","rows":[[[{"inlineContent":[{"text":"Factory","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Description"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":".push(_:root:path:)"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Push a route onto the navigation stack"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":".present(_:withStack:root:path:)"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Present as a sheet"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":".cover(_:root:path:)"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Present as a full-screen cover"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":".popToRoot(root:)","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Reset navigation to root (no final route)"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":".updateRoot(_:)","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Replace the root route only"}],"type":"paragraph"}]]]},{"level":3,"anchor":"Parameters","type":"heading","text":"Parameters"},{"header":"row","type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Parameter"}]}],[{"type":"paragraph","inlineContent":[{"text":"Description","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"root"}]}],[{"type":"paragraph","inlineContent":[{"text":"Optional route to set as the new root (default: ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":")","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"type","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Presentation type for the final route: "},{"type":"codeVoice","code":".push"},{"type":"text","text":", "},{"type":"codeVoice","code":".sheet(withStack:)"},{"type":"text","text":", or "},{"type":"codeVoice","code":".cover"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"route","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Optional final destination route (default: ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" for reset scenarios)","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"path","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Array of intermediate routes to push first (default: "},{"type":"codeVoice","code":"[]"},{"type":"text","text":")"}]}]]]},{"content":[{"type":"paragraph","inlineContent":[{"text":"When ","type":"text"},{"code":"route","type":"codeVoice"},{"text":" is ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" (e.g., with ","type":"text"},{"code":".popToRoot()","type":"codeVoice"},{"text":"), the final navigation step is skipped. The ","type":"text"},{"code":"type","type":"codeVoice"},{"text":" parameter is set automatically by factory methods.","type":"text"}]}],"name":"Note","type":"aside","style":"note"},{"level":2,"anchor":"Handling-Deep-Links","type":"heading","text":"Handling Deep Links"},{"inlineContent":[{"text":"Use the router’s ","type":"text"},{"code":"handle(deeplink:)","type":"codeVoice"},{"text":" method:","type":"text"}],"type":"paragraph"},{"code":["struct ContentView: View {","    var body: some View {","        RoutingView(destination: HomeRoute.self, root: .home) {","            HomeRootView()","        }","    }","}","","struct HomeRootView: View {","    @Environment(\\.router) private var router","    let handler = AppDeeplinkHandler()","","    var body: some View {","        HomeView()","            .onOpenURL { url in","                Task {","                    guard let identifier = DeeplinkIdentifier(url: url) else { return }","                    guard let deeplink = try await handler.deeplink(from: identifier) else { return }","                    router.handle(deeplink: deeplink)","                }","            }","    }","}"],"syntax":"swift","type":"codeListing"},{"content":[{"inlineContent":[{"type":"text","text":""},{"type":"text","text":" "},{"type":"text","text":"The route type returned by "},{"code":"DeeplinkHandler","type":"codeVoice"},{"type":"text","text":" ("},{"code":"D","type":"codeVoice"},{"type":"text","text":") must match the route type used by "},{"code":"RoutingView(destination:root:)","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}],"name":"Note","type":"aside","style":"note"},{"level":3,"anchor":"What-handledeeplink-Does","type":"heading","text":"What handle(deeplink:) Does"},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Closes all presented modals ("},{"type":"codeVoice","code":"closeChildren()"},{"type":"text","text":")"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Pops to the root ("},{"type":"codeVoice","code":"popToRoot()"},{"type":"text","text":")"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Optionally updates the root route (if "},{"type":"codeVoice","code":"root"},{"type":"text","text":" is set)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Pushes intermediate routes from ","type":"text"},{"code":"path","type":"codeVoice"}]}]},{"content":[{"inlineContent":[{"text":"Navigates to the final route with the specified type (only if ","type":"text"},{"code":"route","type":"codeVoice"},{"text":" is not ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":")","type":"text"}],"type":"paragraph"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Step 5 is skipped when ","type":"text"},{"code":"route","type":"codeVoice"},{"text":" is ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":", making ","type":"text"},{"code":".popToRoot()","type":"codeVoice"},{"text":" and ","type":"text"},{"code":".updateRoot(_:)","type":"codeVoice"},{"text":" useful for reset scenarios without a final destination.","type":"text"}]}],"name":"Note","type":"aside","style":"note"},{"level":3,"anchor":"Complete-Example","type":"heading","text":"Complete Example"},{"code":["\/\/ Deep link: reset to dashboard, build path, then push detail as sheet",".present(","    .orderDetail(id: orderId),","    root: .dashboard,","    path: [.orders, .orderList]",")"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"This will:","type":"text"}],"type":"paragraph"},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"text":"Close any presented modals","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Pop to root","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Set "},{"code":".dashboard","type":"codeVoice"},{"type":"text","text":" as the new root"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Push "},{"type":"codeVoice","code":".orders"},{"type":"text","text":" then "},{"type":"codeVoice","code":".orderList"},{"type":"text","text":" onto the stack"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Present ","type":"text"},{"code":".orderDetail(id:)","type":"codeVoice"},{"text":" as a sheet","type":"text"}]}]}]},{"level":2,"anchor":"Async-Deep-Link-Handling","type":"heading","text":"Async Deep Link Handling"},{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"deeplink(from:)"},{"type":"text","text":" method is "},{"type":"codeVoice","code":"async"},{"type":"text","text":", allowing you to fetch data before navigation:"}],"type":"paragraph"},{"code":["func deeplink(from route: DeeplinkIdentifier) async throws -> DeeplinkRoute<HomeRoute>? {","    switch route {","    case .product(let productId):","        \/\/ Fetch product details before navigating","        let product = try await productService.fetch(id: productId)","        return .push(.productDetail(product))","        ","    case .user(let userId):","        \/\/ Validate user exists","        guard await userService.exists(id: userId) else {","            return nil  \/\/ Return nil to ignore invalid deep links","        }","        return .push(.profile(userId: userId))","        ","    default:","        return nil","    }","}"],"syntax":"swift","type":"codeListing"},{"level":2,"anchor":"Composing-Deeplink-Handlers-Nested-Route-Logic","type":"heading","text":"Composing Deeplink Handlers (Nested Route Logic)"},{"inlineContent":[{"type":"text","text":"For larger apps, compose deep link handling by feature instead of keeping all cases in one switch."},{"type":"text","text":" "},{"type":"text","text":"This works well with nested route structures."}],"type":"paragraph"},{"code":["enum AppRoute: Route {","    case home","    case profile(ProfileRoute)","","    var name: String {","        switch self {","        case .home: \"home\"","        case .profile(let child): \"profile.\\(child.name)\"","        }","    }","}","","enum ProfileRoute: Route {","    case overview","    case edit(userId: String)","","    var name: String {","        switch self {","        case .overview: \"overview\"","        case .edit(let userId): \"edit(\\(userId))\"","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"Create feature-level handlers:"}],"type":"paragraph"},{"code":["enum ProfileDeeplinkID: Hashable, Sendable {","    case profile(userId: String)","    case editProfile(userId: String)","}","","struct ProfileDeeplinkHandler: DeeplinkHandler {","    typealias R = ProfileDeeplinkID","    typealias D = AppRoute","","    func deeplink(from route: ProfileDeeplinkID) async throws -> DeeplinkRoute<AppRoute>? {","        switch route {","        case .profile(let userId):","            return .push(.profile(.overview), path: [.home])","        case .editProfile(let userId):","            return .push(.profile(.edit(userId: userId)))","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"Then compose at the app level:"}],"type":"paragraph"},{"code":["enum AppDeeplinkID: Hashable, Sendable {","    case home","    case profile(ProfileDeeplinkID)","    case reset","}","","struct AppDeeplinkHandler: DeeplinkHandler {","    typealias R = AppDeeplinkID","    typealias D = AppRoute","","    private let profileHandler = ProfileDeeplinkHandler()","","    func deeplink(from route: AppDeeplinkID) async throws -> DeeplinkRoute<AppRoute>? {","        switch route {","        case .home:","            return .push(.home)","        case .profile(let profileID):","            return try await profileHandler.deeplink(from: profileID)","        case .reset:","            return .popToRoot()","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"Benefits:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"keeps handlers small and feature-focused"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"mirrors your nested route architecture","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"makes deeplink behavior easier to test"}],"type":"paragraph"}]}]},{"level":2,"anchor":"Tab-Based-Deep-Links","type":"heading","text":"Tab-Based Deep Links"},{"inlineContent":[{"text":"For apps with tab navigation, implement ","type":"text"},{"identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/TabDeeplinkHandler","isActive":true,"type":"reference"},{"text":" and return a ","type":"text"},{"identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/TabDeeplink","isActive":true,"type":"reference"},{"text":". The ","type":"text"},{"code":"deeplink","type":"codeVoice"},{"text":" property accepts any ","type":"text"},{"identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/DeeplinkRoute","isActive":true,"type":"reference"},{"text":", including reset scenarios with ","type":"text"},{"code":".popToRoot()","type":"codeVoice"},{"text":":","type":"text"}],"type":"paragraph"},{"code":["struct AppTabDeeplinkHandler: TabDeeplinkHandler {","    typealias R = DeeplinkIdentifier","    typealias T = HomeTab","    typealias D = HomeRoute","","    func deeplink(from route: DeeplinkIdentifier) async throws -> TabDeeplink<HomeTab, HomeRoute>? {","        switch route {","        case .profile(let userId):","            return TabDeeplink(","                tab: .profile,","                deeplink: .push(.profile(userId: userId))","            )","            ","        case .search(let query):","            return TabDeeplink(","                tab: .search,","                deeplink: .push(.searchResults(query: query), path: [.search])","            )","            ","        case .resetHome:","            return TabDeeplink(tab: .home, deeplink: .popToRoot())","            ","        default:","            return nil","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"The "},{"code":"handle(tabDeeplink:)","type":"codeVoice"},{"text":" method switches to the specified tab, then delegates to ","type":"text"},{"code":"handle(deeplink:)","type":"codeVoice"},{"text":" on that tab’s router. This means all ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/DeeplinkRoute","type":"reference"},{"text":" factories work seamlessly within tabs, including ","type":"text"},{"code":".popToRoot()","type":"codeVoice"},{"text":" for resetting a specific tab’s navigation.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Handle with TabRouter:","type":"text"}],"type":"paragraph"},{"code":["@Environment(\\.router) private var router","","func handleDeeplink(_ url: URL) async throws {","    guard let identifier = DeeplinkIdentifier(url: url) else { return }","    guard let tabDeeplink = try await handler.deeplink(from: identifier) else { return }","    router.tabRouter?.handle(tabDeeplink: tabDeeplink)","}"],"syntax":"swift","type":"codeListing"},{"content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"tabRouter"},{"text":" is injected inside ","type":"text"},{"type":"codeVoice","code":"RoutingTabView"},{"text":" descendants.","type":"text"},{"text":" ","type":"text"},{"text":"If deeplink handling is implemented in a parent container that owns ","type":"text"},{"type":"codeVoice","code":"RoutingTabView"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"use ","type":"text"},{"type":"codeVoice","code":"@Environment(\\.router)"},{"text":" and then ","type":"text"},{"type":"codeVoice","code":"router.tabRouter"},{"text":" to access the tab router.","type":"text"}]}],"name":"Note","type":"aside","style":"note"},{"level":2,"anchor":"Building-Navigation-Paths","type":"heading","text":"Building Navigation Paths"},{"inlineContent":[{"type":"text","text":"For complex deep links, build a path of intermediate routes:"}],"type":"paragraph"},{"code":["\/\/ Deep link to: Home → Category → Subcategory → Product",".push(","    .product(id: productId),","    path: [","        .category(id: categoryId),","        .subcategory(id: subcategoryId)","    ]",")"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"This ensures the back button works correctly through the entire hierarchy."}],"type":"paragraph"},{"level":2,"anchor":"Resetting-Navigation","type":"heading","text":"Resetting Navigation"},{"inlineContent":[{"type":"text","text":"Use "},{"code":".popToRoot()","type":"codeVoice"},{"type":"text","text":" to reset navigation without navigating to a specific route:"}],"type":"paragraph"},{"code":["\/\/ Simply reset to root",".popToRoot()","","\/\/ Reset and change the root route",".popToRoot(root: .dashboard)","","\/\/ Update root only (no popToRoot, no path navigation)",".updateRoot(.newHome)"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"These are useful for logout flows, session resets, or returning users to a clean state."}],"type":"paragraph"},{"level":2,"anchor":"Error-Handling","type":"heading","text":"Error Handling"},{"inlineContent":[{"text":"Return ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" from ","type":"text"},{"code":"deeplink(from:)","type":"codeVoice"},{"text":" to ignore invalid deep links:","type":"text"}],"type":"paragraph"},{"code":["func deeplink(from route: DeeplinkIdentifier) async throws -> DeeplinkRoute<HomeRoute>? {","    guard isValidRoute(route) else {","        return nil  \/\/ Silently ignore","    }","    ","    \/\/ Or throw for error handling","    guard let data = try await fetchData(for: route) else {","        throw DeeplinkError.notFound","    }","    ","    return .push(.detail(data))","}"],"syntax":"swift","type":"codeListing"}],"kind":"content"}],"kind":"article","identifier":{"url":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/Deeplinks","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/SwiftRouting\/documentation\/SwiftRouting"],["doc:\/\/SwiftRouting\/documentation\/SwiftRouting","doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/Migration"]]},"references":{"doc://SwiftRouting/documentation/SwiftRouting":{"role":"collection","kind":"symbol","abstract":[{"type":"text","text":"A lightweight, type-safe navigation framework built on top of NavigationStack for SwiftUI."}],"title":"SwiftRouting","url":"\/documentation\/swiftrouting","identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting","type":"topic"},"doc://SwiftRouting/documentation/SwiftRouting/Migration":{"abstract":[{"text":"Adopt SwiftRouting in an existing SwiftUI app with minimal disruption.","type":"text"}],"identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/Migration","url":"\/documentation\/swiftrouting\/migration","kind":"article","type":"topic","role":"collectionGroup","title":"Migrating from NavigationStack"},"doc://SwiftRouting/documentation/SwiftRouting/DeeplinkRoute":{"kind":"article","type":"topic","role":"collectionGroup","url":"\/documentation\/swiftrouting\/deeplinkroute","abstract":[{"text":"Define navigation instructions for deep links using factory methods.","type":"text"}],"identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/DeeplinkRoute","title":"DeeplinkRoute"},"doc://SwiftRouting/docume