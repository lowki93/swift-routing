{"kind":"article","sections":[],"abstract":[{"type":"text","text":"Adopt SwiftRouting in an existing SwiftUI app with minimal disruption."}],"hierarchy":{"paths":[["doc:\/\/SwiftRouting\/documentation\/SwiftRouting"]]},"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","level":2,"type":"heading","anchor":"Overview"},{"inlineContent":[{"text":"If your app already uses ","type":"text"},{"type":"codeVoice","code":"NavigationStack"},{"text":", ","type":"text"},{"type":"codeVoice","code":"NavigationLink"},{"text":", or native sheet\/cover modifiers, you can migrate to SwiftRouting incrementally. This guide walks through each common pattern and shows the equivalent SwiftRouting code.","type":"text"}],"type":"paragraph"},{"text":"NavigationStack → RoutingView","level":2,"type":"heading","anchor":"NavigationStack-%E2%86%92-RoutingView"},{"text":"Before","level":3,"type":"heading","anchor":"Before"},{"syntax":"swift","code":["@State private var path = NavigationPath()","","var body: some View {","    NavigationStack(path: $path) {","        HomeView()","            .navigationDestination(for: String.self) { value in","                if value == \"detail\" {","                    DetailView()","                } else if value == \"settings\" {","                    SettingsView()","                }","            }","    }","}"],"type":"codeListing"},{"text":"After","level":3,"type":"heading","anchor":"After"},{"inlineContent":[{"type":"text","text":"Define your routes as a Swift enum, then replace the stack with "},{"type":"reference","identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/RoutingView","isActive":true},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"swift","code":["enum HomeRoute: Route {","    case home","    case detail(id: Int)","    case settings","","    var name: String {","        switch self {","        case .home: \"home\"","        case .detail(let id): \"detail(\\(id))\"","        case .settings: \"settings\"","        }","    }","}","","extension HomeRoute: RouteDestination {","    static func view(for route: HomeRoute) -> some View {","        switch route {","        case .home: HomeView()","        case .detail(let id): DetailView(id: id)","        case .settings: SettingsView()","        }","    }","}","","var body: some View {","    RoutingView(destination: HomeRoute.self, root: .home)","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"All "},{"type":"codeVoice","code":"navigationDestination"},{"type":"text","text":" registrations are replaced by a single "},{"type":"codeVoice","code":"RouteDestination"},{"type":"text","text":" conformance."}],"type":"paragraph"},{"text":"NavigationLink → router.push","level":2,"type":"heading","anchor":"NavigationLink-%E2%86%92-routerpush"},{"text":"Before","level":3,"type":"heading","anchor":"Before"},{"syntax":"swift","code":["NavigationLink(\"View Details\", value: \"detail\")","","\/\/ Or with a destination view","NavigationLink(\"View Details\") {","    DetailView(id: 42)","}"],"type":"codeListing"},{"text":"After","level":3,"type":"heading","anchor":"After"},{"inlineContent":[{"type":"text","text":"Use "},{"type":"codeVoice","code":"router.push(_:)"},{"type":"text","text":" or the SwiftRouting "},{"type":"codeVoice","code":"NavigationLink(route:)"},{"type":"text","text":" extension:"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Programmatic push","Button(\"View Details\") {","    router.push(HomeRoute.detail(id: 42))","}","","\/\/ Declarative NavigationLink","NavigationLink(\"View Details\", route: HomeRoute.detail(id: 42))"],"type":"codeListing"},{"content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"type":"codeVoice","code":"NavigationLink(route:)"},{"text":" performs push navigation only. For modal presentation, use ","type":"text"},{"type":"codeVoice","code":"router.present(_:)"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"router.cover(_:)"},{"text":".","type":"text"}]}],"type":"aside","name":"Important","style":"important"},{"text":"Sheets → router.present","level":2,"type":"heading","anchor":"Sheets-%E2%86%92-routerpresent"},{"text":"Before","level":3,"type":"heading","anchor":"Before"},{"syntax":"swift","code":["@State private var showSettings = false","","var body: some View {","    Button(\"Open Settings\") {","        showSettings = true","    }","    .sheet(isPresented: $showSettings) {","        SettingsView()","    }","}"],"type":"codeListing"},{"text":"After","level":3,"type":"heading","anchor":"After"},{"syntax":"swift","code":["@Environment(\\.router) private var router","","Button(\"Open Settings\") {","    router.present(HomeRoute.settings)","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"If you need sheet presentation modifiers such as "},{"type":"codeVoice","code":"presentationDetents"},{"type":"text","text":", present without a navigation stack:"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ In your route definition","var routingType: RoutingType { .sheet(withStack: false) }","","\/\/ Or inline","router.present(HomeRoute.settings, withStack: false)"],"type":"codeListing"},{"text":"Full-Screen Cover → router.cover","level":2,"type":"heading","anchor":"Full-Screen-Cover-%E2%86%92-routercover"},{"text":"Before","level":3,"type":"heading","anchor":"Before"},{"syntax":"swift","code":["@State private var showOnboarding = false","","var body: some View {","    Button(\"Start Onboarding\") {","        showOnboarding = true","    }","    .fullScreenCover(isPresented: $showOnboarding) {","        OnboardingView()","    }","}"],"type":"codeListing"},{"text":"After","level":3,"type":"heading","anchor":"After"},{"syntax":"swift","code":["Button(\"Start Onboarding\") {","    router.cover(HomeRoute.onboarding)","}"],"type":"codeListing"},{"text":"TabView → RoutingTabView","level":2,"type":"heading","anchor":"TabView-%E2%86%92-RoutingTabView"},{"text":"Before","level":3,"type":"heading","anchor":"Before"},{"syntax":"swift","code":["@State private var selectedTab = 0","","TabView(selection: $selectedTab) {","    HomeView()","        .tabItem { Label(\"Home\", systemImage: \"house\") }","        .tag(0)","","    SearchView()","        .tabItem { Label(\"Search\", systemImage: \"magnifyingglass\") }","        .tag(1)","","    ProfileView()","        .tabItem { Label(\"Profile\", systemImage: \"person\") }","        .tag(2)","}"],"type":"codeListing"},{"text":"After — Option 1: RoutingTabView (recommended)","level":3,"type":"heading","anchor":"After-Option-1-RoutingTabView-recommended"},{"inlineContent":[{"type":"text","text":"Use "},{"code":"RoutingTabView","type":"codeVoice"},{"type":"text","text":" when you need programmatic cross-tab navigation via "},{"identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/TabRouter","type":"reference","isActive":true},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"swift","code":["enum HomeTab: TabRoute {","    case home","    case search","    case profile","","    var name: String {","        switch self {","        case .home: \"home\"","        case .search: \"search\"","        case .profile: \"profile\"","        }","    }","}","","struct ContentView: View {","    @State private var selectedTab: HomeTab = .home","","    var body: some View {","        RoutingTabView(tab: $selectedTab, destination: HomeRoute.self) { destination in","            RoutingView(tab: .home, destination: destination, root: .home)","                .tabItem { Label(\"Home\", systemImage: \"house\") }","","            RoutingView(tab: .search, destination: destination, root: .search)","                .tabItem { Label(\"Search\", systemImage: \"magnifyingglass\") }","","            RoutingView(tab: .profile, destination: destination, root: .profile)","                .tabItem { Label(\"Profile\", systemImage: \"person\") }","        }","    }","}"],"type":"codeListing"},{"text":"After — Option 2: Native TabView with .tabToRoot","level":3,"type":"heading","anchor":"After-Option-2-Native-TabView-with-tabToRoot"},{"inlineContent":[{"text":"For simpler cases without programmatic tab control:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["struct ContentView: View {","    @Environment(\\.router) private var router","    @State private var selectedTab: HomeTab = .home","","    var body: some View {","        TabView(selection: .tabToRoot(for: $selectedTab, in: router)) {","            RoutingView(tab: .home, destination: HomeRoute.self, root: .home)","                .tabItem { Label(\"Home\", systemImage: \"house\") }","","            RoutingView(tab: .search, destination: HomeRoute.self, root: .search)","                .tabItem { Label(\"Search\", systemImage: \"magnifyingglass\") }","","            RoutingView(tab: .profile, destination: HomeRoute.self, root: .profile)","                .tabItem { Label(\"Profile\", systemImage: \"person\") }","        }","    }","}"],"type":"codeListing"},{"inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":".tabToRoot"},{"text":" binding automatically pops to root when the user taps the already-selected tab.","type":"text"}],"type":"paragraph"},{"content":[{"inlineContent":[{"text":"This option does ","type":"text"},{"type":"strong","inlineContent":[{"text":"not","type":"text"}]},{"text":" provide ","type":"text"},{"code":"@Environment(\\.tabRouter)","type":"codeVoice"},{"text":". Use ","type":"text"},{"code":"RoutingTabView","type":"codeVoice"},{"text":" when cross-tab programmatic navigation is needed.","type":"text"}],"type":"paragraph"}],"type":"aside","name":"Important","style":"important"},{"text":"Deep Links","level":2,"type":"heading","anchor":"Deep-Links"},{"text":"Before","level":3,"type":"heading","anchor":"Before"},{"inlineContent":[{"text":"Deep link handling typically required parsing URLs and manually mutating ","type":"text"},{"type":"codeVoice","code":"NavigationPath"},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":[".onOpenURL { url in","    if url.path == \"\/detail\" {","        path.append(\"detail\")","    }","}"],"type":"codeListing"},{"text":"After","level":3,"type":"heading","anchor":"After"},{"inlineContent":[{"type":"text","text":"Define a typed identifier enum ("},{"code":"Hashable & Sendable","type":"codeVoice"},{"type":"text","text":") to represent your deep link inputs, then implement "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/DeeplinkHandler"},{"type":"text","text":" to map it to a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/DeeplinkRoute"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"swift","code":["enum AppDeeplinkIdentifier: Hashable, Sendable {","    case detail(id: Int)","}","","extension AppDeeplinkIdentifier {","    init?(url: URL) {","        switch url.path {","        case \"\/detail\":","            guard let id = Int(url.lastPathComponent) else { return nil }","            self = .detail(id: id)","        default:","            return nil","        }","    }","}","","struct HomeDeeplinkHandler: DeeplinkHandler {","    typealias R = AppDeeplinkIdentifier","    typealias D = HomeRoute","","    func deeplink(from route: AppDeeplinkIdentifier) async throws -> DeeplinkRoute<HomeRoute>? {","        switch route {","        case .detail(let id):","            return .push(.detail(id: id))","        }","    }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Parse the URL into the identifier inside "},{"type":"codeVoice","code":".onOpenURL"},{"type":"text","text":", then pass it to the handler:"}],"type":"paragraph"},{"syntax":"swift","code":["struct HomeRootView: View {","    @Environment(\\.router) private var router","    let handler = HomeDeeplinkHandler()","","    var body: some View {","        HomeView()","            .onOpenURL { url in","                Task {","                    guard let identifier = AppDeeplinkIdentifier(url: url) else { return }","                    guard let deeplink = try? await handler.deeplink(from: identifier) else { return }","                    router.handle(deeplink: deeplink)","                }","            }","    }","}"],"type":"codeListing"},{"inlineContent":[{"text":"See ","type":"text"},{"identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/Deeplinks","isActive":true,"type":"reference"},{"text":" for advanced patterns including path building, async data fetching, and tab-aware deep linking.","type":"text"}],"type":"paragraph"},{"text":"Dismissing Modals","level":2,"type":"heading","anchor":"Dismissing-Modals"},{"text":"Before","level":3,"type":"heading","anchor":"Before"},{"syntax":"swift","code":["@Environment(\\.dismiss) private var dismiss","","Button(\"Close\") {","    dismiss()","}"],"type":"codeListing"},{"text":"After","level":3,"type":"heading","anchor":"After"},{"syntax":"swift","code":["@Environment(\\.router) private var router","","Button(\"Close\") {","    router.close()","}"],"type":"codeListing"},{"inlineContent":[{"type":"codeVoice","code":"router.close()"},{"type":"text","text":" dismisses the current presented modal. It is a no-op if the router is not presented."}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiftrouting\/migration"]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/Migration"},"topicSections":[{"title":"Related","anchor":"Related","identifiers":["doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/GettingStarted","doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/NavigationBasics","doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/Deeplinks","doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/RoutingView","doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/Ro