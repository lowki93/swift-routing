{"abstract":[{"type":"text","text":"Understand the design principles and structure behind SwiftRouting."}],"identifier":{"url":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/Architecture","interfaceLanguage":"swift"},"topicSections":[{"title":"Related","anchor":"Related","identifiers":["doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/Router","doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/RouterModel","doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/TabRouter","doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/RoutingView"]}],"variants":[{"paths":["\/documentation\/swiftrouting\/architecture"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"text":"SwiftRouting is built around a few core principles: ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"separation of concerns"}]},{"text":", ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"type safety"}]},{"text":", and ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"testability"}]},{"text":". This guide explains how these principles shape the framework’s architecture.","type":"text"}]},{"type":"heading","level":2,"text":"Design Principles","anchor":"Design-Principles"},{"type":"heading","level":3,"text":"Routes Are Data, Not Views","anchor":"Routes-Are-Data-Not-Views"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In SwiftRouting, routes are simple Swift enums that describe "},{"type":"emphasis","inlineContent":[{"type":"text","text":"what"}]},{"type":"text","text":" destination to navigate to, not "},{"type":"emphasis","inlineContent":[{"type":"text","text":"how"}]},{"type":"text","text":" to display it:"}]},{"type":"codeListing","syntax":"swift","code":["enum AppRoute: Route {","    case home","    case profile(userId: String)","    case settings","}"]},{"type":"paragraph","inlineContent":[{"text":"The view mapping is handled separately through ","type":"text"},{"code":"RouteDestination","type":"codeVoice"},{"text":":","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["extension AppRoute: RouteDestination {","    static func view(for route: AppRoute) -> some View {","        switch route {","        case .home: HomeView()","        case .profile(let userId): ProfileView(userId: userId)","        case .settings: SettingsView()","        }","    }","}"]},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Why this separation?"}]}],"type":"paragraph"},{"rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Benefit"}]}],[{"inlineContent":[{"type":"text","text":"Explanation"}],"type":"paragraph"}]],[[{"inlineContent":[{"inlineContent":[{"text":"Reusability","type":"text"}],"type":"strong"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Routes can be used in navigation, deep links, analytics, and tests without view dependencies"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Testability","type":"text"}]}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Test navigation logic by asserting on route values, not view hierarchies"}],"type":"paragraph"}]],[[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Flexibility"}],"type":"strong"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Change view implementations without touching route definitions"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Modularity","type":"text"}]}],"type":"paragraph"}],[{"inlineContent":[{"text":"Routes can live in a shared module; views in feature modules","type":"text"}],"type":"paragraph"}]]],"header":"row","type":"table"},{"text":"Protocol-Based Router","level":3,"type":"heading","anchor":"Protocol-Based-Router"},{"inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/Router","isActive":true,"type":"reference"},{"text":" class implements the ","type":"text"},{"identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/RouterModel","isActive":true,"type":"reference"},{"text":" protocol, which defines all navigation operations:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["public protocol RouterModel {","    func push(_ route: some Route)","    func present(_ route: some Route, withStack: Bool)","    func cover(_ route: some Route)","    func back()","    func popToRoot()","    func close()","    \/\/ ...","}"]},{"inlineContent":[{"text":"This protocol-based design enables:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Dependency injection","type":"text"}],"type":"strong"},{"text":" in ViewModels","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Mocking"}]},{"type":"text","text":" for unit tests"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Abstraction"}],"type":"strong"},{"type":"text","text":" over concrete router implementations"}]}]}],"type":"unorderedList"},{"text":"Hierarchical Router Structure","level":3,"type":"heading","anchor":"Hierarchical-Router-Structure"},{"inlineContent":[{"type":"text","text":"SwiftRouting creates a hierarchy of routers that mirrors your navigation structure."}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Without tabs"}]},{"type":"text","text":" (single stack):"}],"type":"paragraph"},{"syntax":null,"type":"codeListing","code":["App","└── RoutingView","    └── Router  root: .home","        ├── push(.list)","        │   └── Stack: [.home, .list]          (same Router)","        └── present(.detail)","            └── Router  root: .detail          (child Router, sheet)","                └── push(.comments)","                    └── Stack: [.detail, .comments]"]},{"inlineContent":[{"inlineContent":[{"type":"text","text":"With tabs"}],"type":"strong"},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":null,"type":"codeListing","code":["App","└── RoutingTabView","    └── TabRouter","        ├── RoutingView [Home Tab]","        │   └── Router  root: .home","        │       ├── push(.list)","        │       │   └── Stack: [.home, .list]          (same Router)","        │       └── present(.detail)","        │           └── Router  root: .detail          (child Router, sheet)","        │               └── push(.comments)","        │                   └── Stack: [.detail, .comments]","        ├── RoutingView [Search Tab]","        │   └── Router  root: .search","        └── RoutingView [Profile Tab]","            └── Router  root: .profile"]},{"inlineContent":[{"text":"Each ","type":"text"},{"identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/RoutingView","isActive":true,"type":"reference"},{"text":" creates its own ","type":"text"},{"identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/Router","isActive":true,"type":"reference"},{"text":". When you present a sheet or cover, a new child router is created. This hierarchy enables:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Scoped navigation"}]},{"type":"text","text":": Each router manages its own stack"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Context propagation"}],"type":"strong"},{"text":": ","type":"text"},{"code":"RouteContext","type":"codeVoice"},{"text":" flows up through the hierarchy","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Coordinated dismissal"}],"type":"strong"},{"text":": ","type":"text"},{"code":"closeChildren()","type":"codeVoice"},{"text":" dismisses all descendants","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"text":"Component Relationships","level":2,"type":"heading","anchor":"Component-Relationships"},{"syntax":null,"type":"codeListing","code":["┌─────────────────────────────────────────────────────────────┐","│                        RoutingTabView                        │","│                             │                               │","│                        TabRouter                            │","│               ┌─────────────┼─────────────┐                │","│               ▼             ▼             ▼                │","│         RoutingView    RoutingView    RoutingView           │","│              │                                              │","│           Router  ◀── @Environment(\\.router)               │","│           │    │                                            │","│      path │    │ sheet \/ cover                             │","│           ▼    ▼                                            │","│        Routes  Child Router (weak ref to parent)           │","│                │                                            │","│            contexts: [RouteContext observers]               │","└─────────────────────────────────────────────────────────────┘"]},{"text":"RoutingView","level":3,"type":"heading","anchor":"RoutingView"},{"inlineContent":[{"isActive":true,"identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/RoutingView","type":"reference"},{"type":"text","text":" is the entry point that creates a "},{"type":"codeVoice","code":"NavigationStack"},{"type":"text","text":" with an associated "},{"isActive":true,"identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/Router","type":"reference"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["RoutingView(destination: AppRoute.self, root: .home)"]},{"inlineContent":[{"type":"text","text":"It:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Creates a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/Router"},{"text":" instance","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Injects it into the environment via ","type":"text"},{"code":"@Environment(\\.router)","type":"codeVoice"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Registers the "},{"type":"codeVoice","code":"RouteDestination"},{"type":"text","text":" for navigation"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Manages sheet and cover presentations","type":"text"}]}]}],"type":"orderedList"},{"text":"Router","level":3,"type":"heading","anchor":"Router"},{"inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/Router"},{"text":" manages:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Navigation path","type":"text"}],"type":"strong"},{"type":"text","text":": The stack of pushed routes"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Root route","type":"text"}],"type":"strong"},{"type":"text","text":": The initial route displayed"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Presentations","type":"text"}]},{"text":": Sheet and cover modals","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Context observers"}]},{"type":"text","text":": Registered "},{"type":"codeVoice","code":"RouteContext"},{"type":"text","text":" handlers"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Child routers"}]},{"type":"text","text":": Routers created by presented modals"}],"type":"paragraph"}]}],"type":"unorderedList"},{"text":"TabRouter","level":3,"type":"heading","anchor":"TabRouter"},{"inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/TabRouter"},{"type":"text","text":" coordinates navigation across tabs:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"Manages the selected tab","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Provides access to each tab’s "},{"type":"reference","identifier":"doc:\/\/SwiftRouting\/documentation\/SwiftRouting\/Router","isActive":true}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Enables cross-tab navigation ("},{"code":"push(_:in:)","type":"codeVoice"},{"type":"text","text":", "},{"code":"popToRoot(in:)","type":"codeVoice"},{"type":"text","text":")"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Handles tab-aware deep links"}],"type":"paragraph"}]}],"type":"unorderedList"},{"text":"Data Flow","level":2,"type":"heading","anchor":"Data-Flow"},{"text":"Navigation Flow","level":3,"type":"heading","anchor":"Navigation-Flow"},{"inlineContent":[{"type":"text","text":"Each navigation type operates differently on the router hierarchy:"}],"type":"paragraph"},{"syntax":null,"type":"codeListing","code":["push(_:)","    │","    ├── Appends route to NavigationStack path","    ├── Same Router instance handles the new route","    └── back() or popToRoot() to unwind","","present(_:)  \/  cover(_:)","    │","    ├── Creates a new child Router","    ├── Presented as .sheet (present) or .fullScreenCover (cover)","    ├── Child Router manages its own NavigationStack","    └── close() or terminate(_:) to dismiss","","","User Action        Router Method         State Change         SwiftUI Result","─────────────      ─────────────         ────────────         ──────────────","Button tap    ──▶  push(.detail)    ──▶  path += [.detail]  ──▶  New view pushed","Link tapped   ──▶  present(.form)   ──▶  child Router set   ──▶  Sheet appears","Back gesture  ──▶  back()           ──▶  path.removeLast()  ──▶  View popped","Dismiss swipe ──▶  close()          ──▶  child Router = nil ──▶  Sheet dismissed","Deep link     ──▶  handle(_:)       ──▶  path replaced      ──▶  Stack rebuilt"]},{"text":"Context Flow","level":3,"type":"heading","anchor":"Context-Flow"},{"inlineContent":[{"code":"RouteContext","type":"codeVoice"},{"text":" flows upward through the router hierarchy:","type":"text"}],"type":"paragraph"},{"syntax":null,"type":"codeListing","code":["Child Router                    Parent Router","     │                               │","     │ router.terminate(context) ────▶│ .routerContext handler executes","     │                               │","     │◀──── Navigation completes ────│"]},{"text":"RouterContext Lifecycle","level":4,"type":"heading","anchor":"RouterContext-Lifecycle"},{"syntax":null,"type":"codeListing","code":["                    ┌─────────────────────────────────────┐","                    │           Parent Router              │","                    │                                      │","  add(context:) ──▶ │  contexts: [SelectionContext: {...}] │","                    │                                      │","                    └──────────────────┬───────────────────┘","                                       │ context propagates up","                                       │","                    ┌──────────────────▼───────────────────┐","                    │           Child Router               │","                    │                                      │"," context(_:)    ──▶ │  Finds observer in parent hierarchy  │","  terminate(_:) ──▶ │  Executes observer + navigates back  │","                    │                                      │","                    └──────────────────────────────────────┘","","Observer removal:","  • Automatic  ──▶  route popped from stack (back \/ popToRoot)","  • Automatic  ──▶  Router deallocated (sheet dismissed)","  • Manual     ──▶  remove(context:) called explicitly"]},{"text":"Deep Link Flow","level":3,"type":"heading","anchor":"Deep-Link-Flow"},{"syntax":null,"type":"codeListing","code":["URL\/Identifier → DeeplinkHandler → DeeplinkRoute → Router.handle(deeplink:)","                      │                  │                   │","                      │                  │                   └── Executes navigation sequence","                      │                  └── Factory creates navigation instructions","                      └── Async conversion with optional data fetching"]},{"text":"Memory Management","level":2,"type":"heading","anchor":"Memory-Management"},{"text":"Router Lifecycle","level":3,"type":"heading","anchor":"Router-Lifecycle"},{"inlineContent":[{"text":"Routers are retained by their parent ","type":"text"},{"type":"codeVoice","code":"RoutingView"},{"text":". When a view is dismissed:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The router is deallocated"}]}]},{"content":[{"inlineContent":[{"text":"Context observers are automatically cleaned up","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Child routers are released"}]}]}],"type":"orderedList"},{"text":"Context Cleanup","level":3,"type":"heading","anchor":"Context-Cleanup"},{"inlineContent":[{"type":"text","text":"Context observers registered on a route are automatically removed when that route is popped from the stack. This prevents memory leaks and stale callbacks."}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ Observer registered on .list route","router.push(.list)","router.add(context: SelectionContext.self) { ... }","","\/\/ When .list is popped, the observer is automatically removed","router.back()"]},{"text":"Best Practices","level":2,"type":"heading","anchor":"Best-Practices"},{"text":"Keep Routes Focused","level":3,"type":"heading","anchor":"Keep-Routes-Focused"},{"inlineContent":[{"type":"text","text":"One route enum per feature or navigation context:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ Good: Focused route enums","enum HomeRoute: Route { ... }","enum ProfileRoute: Route { ... }","enum SettingsRoute: Route { ... }","","\/\/ Avoid: One massive enum for everything","enum AppRoute: Route {","    case home, homeDetail, homeSettings, profile, profileEdit, ...","}"]},{"text":"Use Nested Routes for Complex Hierarchies","level":3,"type":"heading","anchor":"Use-Nested-Routes-for-Complex-Hierarchies"},{"syntax":"swift","type":"codeListing","code":["enum AppRoute: Route {","    case home","    case profile(ProfileRoute)","    case settings(SettingsRoute)","}"]},{"text":"Inject RouterModel, Not Router","level":3,"type":"heading","anchor":"Inject-RouterModel-Not-Router"},{"inlineContent":[{"type":"text","text":"In ViewModels, depend on the protocol for testability:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["class MyViewModel {","    private let router: any RouterModel","    ","    init(router: any RouterModel) {","        self.router = router","    }","}"]},{"text":"Prefer terminate() Over Manual Navigation","level":3,"type":"heading","anchor":"Prefer-terminate-Over-Manual-Navigation"},{"inlineContent":[{"text":"When completing a flow with context, use ","type":"text"},{"type":"codeVoice","code":"terminate()"},{"text":" instead of manual ","type":"text"},{"type":"codeVoice","code":"back()"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"close()"},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ Good: Let the framework handle navigation","router.terminate(SelectionContext(item: selectedItem))","","\/\/ Avoid: Manual navigation after context","router.context(SelectionContext(item: selectedItem))","router.back() \/\/ o